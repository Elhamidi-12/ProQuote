@page "/access-denied"
@rendermode InteractiveServer

<PageTitle>Access Denied - ProQuote</PageTitle>

<div style="max-width:560px;margin:var(--pq-space-16) auto;padding:0 var(--pq-space-4);">
    <PqCard>
        <h1 class="pq-section-title">Access Denied</h1>
        <p class="pq-body-sm" style="margin-top:var(--pq-space-2);">You do not have permission to access this page.</p>
        <div style="display:flex;gap:var(--pq-space-2);margin-top:var(--pq-space-4);">
            <a href="/"><PqButton Variant="primary">Go Home</PqButton></a>
            <a href="/login"><PqButton Variant="secondary">Sign In</PqButton></a>
        </div>
    </PqCard>
</div>
