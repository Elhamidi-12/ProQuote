@inherits LayoutComponentBase
@inject ThemeService ThemeService

<div class="pq-shell pq-shell--admin">
    <PqSidebar AppName="ProQuote Admin"
               UserName="Admin User"
               UserRole="Admin"
               NavItems="_navItems"
               IsCollapsed="_isSidebarCollapsed"
               IsCollapsedChanged="OnSidebarCollapsedChanged" />
    <main class="pq-shell__main @(_isSidebarCollapsed ? "pq-shell__main--collapsed" : string.Empty)">
        <PqTopBar Title="Admin Portal" UserName="Admin User" UserRole="Admin" NotificationCount="2" OnThemeToggle="ThemeService.ToggleTheme" />
        <section class="pq-shell__content">@Body</section>
    </main>
    <PqToastContainer />
</div>

@code {
    private bool _isSidebarCollapsed;

    private Task OnSidebarCollapsedChanged(bool isCollapsed)
    {
        _isSidebarCollapsed = isCollapsed;
        return Task.CompletedTask;
    }

    private readonly List<PqSidebar.SidebarNavItem> _navItems =
    [
        new() { Label = "Dashboard", Href = "/admin/dashboard" },
        new() { Label = "Users", Href = "/admin/users" },
        new() { Label = "Pending Suppliers", Href = "/admin/suppliers/pending" },
        new() { Label = "RFQs", Href = "/admin/rfqs" },
        new() { Label = "Reports", Href = "/admin/reports" },
        new() { Label = "Audit Logs", Href = "/admin/audit-logs" }
    ];
}
