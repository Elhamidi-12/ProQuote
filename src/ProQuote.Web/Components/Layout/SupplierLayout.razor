@inherits LayoutComponentBase
@inject CustomAuthStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Tertiary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3">ProQuote - Supplier Portal</MudText>
        <MudSpacer />
        <MudBadge Content="5" Overlap="true" Color="Color.Error" Class="mx-4">
            <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" />
        </MudBadge>
        <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
            <MudMenuItem Icon="@Icons.Material.Filled.Business" Href="/supplier/company">Company Profile</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.Person" Href="/profile">My Profile</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.Settings" Href="/settings">Settings</MudMenuItem>
            <MudDivider />
            <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="HandleLogoutAsync">Logout</MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu>
            <MudNavLink Href="/supplier/dashboard" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavGroup Title="RFQ Invitations" Icon="@Icons.Material.Filled.Mail" Expanded="true">
                <MudNavLink Href="/supplier/invitations">All Invitations</MudNavLink>
                <MudNavLink Href="/supplier/invitations/new">New</MudNavLink>
                <MudNavLink Href="/supplier/invitations/pending">Pending Response</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="My Quotes" Icon="@Icons.Material.Filled.Description" Expanded="true">
                <MudNavLink Href="/supplier/quotes">All Quotes</MudNavLink>
                <MudNavLink Href="/supplier/quotes/draft">Drafts</MudNavLink>
                <MudNavLink Href="/supplier/quotes/submitted">Submitted</MudNavLink>
                <MudNavLink Href="/supplier/quotes/awarded">Won</MudNavLink>
            </MudNavGroup>
            <MudNavLink Href="/supplier/messages" Icon="@Icons.Material.Filled.Message">Messages</MudNavLink>
            <MudNavLink Href="/supplier/company" Icon="@Icons.Material.Filled.Business">Company Profile</MudNavLink>
            <MudNavLink Href="/supplier/performance" Icon="@Icons.Material.Filled.TrendingUp">Performance</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pt-16 px-4">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task HandleLogoutAsync()
    {
        await AuthStateProvider.MarkUserAsLoggedOutAsync();
        NavigationManager.NavigateTo("/login", forceLoad: true);
    }
}
