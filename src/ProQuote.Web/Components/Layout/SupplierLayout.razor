@inherits LayoutComponentBase
@using System
@using System.Linq
@using System.Security.Claims
@using ProQuote.Application.DTOs.Communication
@using Microsoft.AspNetCore.Components.Authorization
@using ProQuote.Infrastructure.Identity
@using ProQuote.Web.Auth
@inject ThemeService ThemeService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject CustomAuthStateProvider AuthStateProvider
@inject ICommunicationService CommunicationService
@inject ToastService ToastService
@inject PostLoginNotificationStore PostLoginNotificationStore

<div class="pq-shell">
    <PqSidebar AppName="ProQuote Supplier"
               LogoSrc="/_content/ProQuote.UI/assets/proquote-logo.svg"
               UserName="@_userName"
               UserRole="@_userRole"
               NavItems="_navItems"
               IsCollapsed="_isSidebarCollapsed"
               IsCollapsedChanged="OnSidebarCollapsedChanged"
               OnProfile="HandleProfileAsync"
               OnSettings="HandleSettingsAsync"
               OnLogout="HandleLogoutAsync">
        <AppTitle>
            <span class="pq-sidebar__app-title"><span class="pq-sidebar__app-title-pro" style="color:#FFFFFF">Pro</span><span class="pq-sidebar__app-title-quote" style="color:#3B82F6">Quote</span></span>
        </AppTitle>
    </PqSidebar>
    <main class="pq-shell__main @(_isSidebarCollapsed ? "pq-shell__main--collapsed" : string.Empty)">
        <PqTopBar Title="Supplier Portal"
                  NotificationCount="@_notificationCount"
                  Notifications="_notifications"
                  NotificationLoading="_notificationsLoading"
                  OnNotificationsOpen="RefreshNotificationsAsync"
                  OnNotificationClick="HandleNotificationClickAsync"
                  OnMarkAllNotificationsRead="MarkAllNotificationsReadAsync"
                  OnThemeToggle="ThemeService.ToggleThemeAsync" />
        <section class="pq-shell__content">@Body</section>
    </main>
    <PqToastContainer />
</div>

@code {
    private bool _isSidebarCollapsed;
    private string _userName = "Supplier User";
    private string _userRole = "Supplier";
    private Guid? _currentUserId;
    private int _notificationCount;
    private bool _notificationsLoading;
    private List<TopBarNotificationItem> _notifications = [];

    private Task OnSidebarCollapsedChanged(bool isCollapsed)
    {
        _isSidebarCollapsed = isCollapsed;
        return Task.CompletedTask;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadUserAsync();
        await base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadNotificationCountAsync();

            if (PostLoginNotificationStore.TryDequeueSuccess(out string message))
            {
                ToastService.ShowSuccess(message);
            }

            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadUserAsync()
    {
        AuthenticationState authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            UpdateUserFromClaims(authState.User);
            ResolveCurrentUserId(authState.User);
        }
    }

    private void UpdateUserFromClaims(ClaimsPrincipal user)
    {
        string? name = user.Identity?.Name;
        if (!string.IsNullOrWhiteSpace(name))
        {
            _userName = name;
        }

        Claim? roleClaim = user.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role);
        if (roleClaim is not null && !string.IsNullOrWhiteSpace(roleClaim.Value))
        {
            _userRole = roleClaim.Value;
        }
    }

    private Task HandleProfileAsync()
    {
        NavigationManager.NavigateTo(GetProfileRoute());
        return Task.CompletedTask;
    }

    private Task HandleSettingsAsync()
    {
        NavigationManager.NavigateTo(GetSettingsRoute());
        return Task.CompletedTask;
    }

    private Task HandleLogoutAsync()
    {
        NavigationManager.NavigateTo("/logout");
        return Task.CompletedTask;
    }

    private void ResolveCurrentUserId(ClaimsPrincipal user)
    {
        string? userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (!Guid.TryParse(userIdClaim, out Guid userId))
        {
            _currentUserId = null;
            _notificationCount = 0;
            _notifications = [];
            return;
        }

        _currentUserId = userId;
    }

    private async Task RefreshNotificationsAsync()
    {
        if (!_currentUserId.HasValue)
        {
            _notifications = [];
            _notificationCount = 0;
            return;
        }

        _notificationsLoading = true;
        try
        {
            IReadOnlyList<NotificationItemDto> items = await CommunicationService.GetNotificationsAsync(_currentUserId.Value, take: 12);
            _notifications = items
                .Select(n => new TopBarNotificationItem
                {
                    Id = n.Id,
                    Title = n.Title,
                    Message = n.Message,
                    Type = n.Type,
                    ActionUrl = n.ActionUrl,
                    IsRead = n.IsRead,
                    SentAt = n.SentAt
                })
                .ToList();

            _notificationCount = await CommunicationService.GetUnreadNotificationCountAsync(_currentUserId.Value);
        }
        finally
        {
            _notificationsLoading = false;
        }
    }

    private async Task LoadNotificationCountAsync()
    {
        if (!_currentUserId.HasValue)
        {
            _notificationCount = 0;
            return;
        }

        _notificationCount = await CommunicationService.GetUnreadNotificationCountAsync(_currentUserId.Value);
    }

    private async Task HandleNotificationClickAsync(TopBarNotificationItem notification)
    {
        if (!_currentUserId.HasValue)
        {
            return;
        }

        if (!notification.IsRead)
        {
            _ = await CommunicationService.MarkNotificationAsReadAsync(_currentUserId.Value, notification.Id);
            await RefreshNotificationsAsync();
        }

        if (!string.IsNullOrWhiteSpace(notification.ActionUrl))
        {
            NavigationManager.NavigateTo(notification.ActionUrl);
        }
    }

    private async Task MarkAllNotificationsReadAsync()
    {
        if (!_currentUserId.HasValue)
        {
            return;
        }

        _ = await CommunicationService.MarkAllNotificationsAsReadAsync(_currentUserId.Value);
        await RefreshNotificationsAsync();
    }

    private string GetProfileRoute()
    {
        return _userRole switch
        {
            ApplicationRoles.Admin => "/admin/profile",
            ApplicationRoles.Buyer => "/buyer/profile",
            ApplicationRoles.Supplier => "/supplier/profile",
        _ => "/profile"
        };
    }

    private string GetSettingsRoute()
    {
        return _userRole switch
        {
            ApplicationRoles.Admin => "/admin/settings",
            ApplicationRoles.Buyer => "/buyer/settings",
            ApplicationRoles.Supplier => "/supplier/settings",
            _ => "/settings"
        };
    }

    private readonly List<PqSidebar.SidebarNavItem> _navItems =
    [
        new() { Label = "Dashboard", Href = "/supplier/dashboard", Icon = "speedometer2" },
        new() { Label = "Invitations", Href = "/supplier/invitations", Icon = "envelope" },
        new() { Label = "Quotes", Href = "/supplier/quotes", Icon = "receipt" },
        new() { Label = "Messages", Href = "/supplier/messages", Icon = "chat-dots" },
        new() { Label = "Notifications", Href = "/supplier/notifications", Icon = "bell" },
        new() { Label = "Company", Href = "/supplier/company", Icon = "building" }
    ];
}
