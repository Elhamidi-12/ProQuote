@inherits LayoutComponentBase
@inject CustomAuthStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3">ProQuote - Buyer Portal</MudText>
        <MudSpacer />
        <MudBadge Content="3" Overlap="true" Color="Color.Error" Class="mx-4">
            <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" />
        </MudBadge>
        <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
            <MudMenuItem Icon="@Icons.Material.Filled.Person" Href="/profile">Profile</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.Settings" Href="/settings">Settings</MudMenuItem>
            <MudDivider />
            <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="HandleLogoutAsync">Logout</MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu>
            <MudNavLink Href="/buyer/dashboard" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavGroup Title="RFQs" Icon="@Icons.Material.Filled.RequestQuote" Expanded="true">
                <MudNavLink Href="/buyer/rfqs/create" Icon="@Icons.Material.Filled.Add">Create RFQ</MudNavLink>
                <MudNavLink Href="/buyer/rfqs">My RFQs</MudNavLink>
                <MudNavLink Href="/buyer/rfqs/draft">Drafts</MudNavLink>
                <MudNavLink Href="/buyer/rfqs/active">Active</MudNavLink>
                <MudNavLink Href="/buyer/rfqs/awarded">Awarded</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Quotes" Icon="@Icons.Material.Filled.Description" Expanded="false">
                <MudNavLink Href="/buyer/quotes">Received Quotes</MudNavLink>
                <MudNavLink Href="/buyer/quotes/compare">Compare Quotes</MudNavLink>
            </MudNavGroup>
            <MudNavLink Href="/buyer/suppliers" Icon="@Icons.Material.Filled.Business">Suppliers</MudNavLink>
            <MudNavLink Href="/buyer/messages" Icon="@Icons.Material.Filled.Message">Messages</MudNavLink>
            <MudNavLink Href="/buyer/reports" Icon="@Icons.Material.Filled.Assessment">Reports</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pt-16 px-4">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task HandleLogoutAsync()
    {
        await AuthStateProvider.MarkUserAsLoggedOutAsync();
        NavigationManager.NavigateTo("/login", forceLoad: true);
    }
}
