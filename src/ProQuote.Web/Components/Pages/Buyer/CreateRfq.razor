@page "/buyer/rfqs/create"
@page "/buyer/rfqs/{RfqId:guid}/edit"
@rendermode InteractiveServer
@layout BuyerLayout
@attribute [Authorize(Roles = ApplicationRoles.Buyer)]
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using ProQuote.Web.Files
@inject IUnitOfWork UnitOfWork
@inject IAuditLogService AuditLogService
@inject IWebHostEnvironment HostEnvironment
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>@(IsEditMode ? "Edit RFQ" : "Create RFQ") - ProQuote</PageTitle>

<h1 class="pq-section-title">@(IsEditMode ? "Edit RFQ" : "Create RFQ")</h1>

@if (_isLoading)
{
    <PqCard>
        <p class="pq-body-sm">Loading RFQ form...</p>
    </PqCard>
}
else
{
    <div class="pq-flex pq-flex-col pq-gap-4">
        <PqCard>
            <h2 class="pq-card-title">Details</h2>
            <div class="pq-flex pq-flex-col pq-gap-3" style="margin-top:var(--pq-space-3);">
                @if (!string.IsNullOrWhiteSpace(_referenceNumber))
                {
                    <PqInput Label="Reference Number" Value="@_referenceNumber" Disabled="true" />
                }

                <PqInput Label="Title"
                         Value="@_form.Title"
                         ValueChanged="@(v => _form.Title = v ?? string.Empty)"
                         Error="@_errors.GetValueOrDefault(nameof(_form.Title))"
                         Disabled="_isSaving"
                         Required="true" />

                <PqTextarea Label="Description"
                            Value="@_form.Description"
                            ValueChanged="@(v => _form.Description = v)"
                            Disabled="_isSaving" />

                <PqSelect Label="Category"
                          Value="@_form.CategoryId"
                          ValueChanged="@(v => _form.CategoryId = v ?? string.Empty)"
                          Options="_categoryOptions"
                          Placeholder="Select category"
                          Disabled="_isSaving" />
                @if (_errors.TryGetValue(nameof(_form.CategoryId), out string? categoryError))
                {
                    <p class="pq-caption" style="color:var(--pq-danger-text)">@categoryError</p>
                }

                <PqInput Label="Currency"
                         Value="@_form.Currency"
                         ValueChanged="@(v => _form.Currency = v ?? "USD")"
                         Disabled="_isSaving"
                         Required="true" />

                <PqInput Label="Submission Deadline (UTC)"
                         Type="datetime-local"
                         Value="@_form.SubmissionDeadline"
                         ValueChanged="@(v => _form.SubmissionDeadline = v ?? string.Empty)"
                         Error="@_errors.GetValueOrDefault(nameof(_form.SubmissionDeadline))"
                         Disabled="_isSaving"
                         Required="true" />
            </div>
        </PqCard>

        <PqCard>
            <div class="pq-flex pq-justify-between pq-items-center">
                <h2 class="pq-card-title">Line Items</h2>
                <PqButton Variant="secondary" Size="sm" OnClick="AddLineItem" Disabled="_isSaving">Add Item</PqButton>
            </div>

            @if (_lineItems.Count == 0)
            {
                <p class="pq-body-sm" style="margin-top:var(--pq-space-2);">No line items yet.</p>
            }
            else
            {
                <div class="pq-flex pq-flex-col pq-gap-3" style="margin-top:var(--pq-space-3);">
                    @for (int i = 0; i < _lineItems.Count; i++)
                    {
                        int index = i;
                        LineItemForm item = _lineItems[index];
                        <PqCard>
                            <div class="pq-flex pq-justify-between pq-items-center">
                                <h3 class="pq-body-sm">Item @(index + 1)</h3>
                                <PqButton Variant="danger" Size="sm" OnClick="@(() => RemoveLineItem(index))" Disabled="_isSaving">Remove</PqButton>
                            </div>
                            <div class="pq-flex pq-flex-col pq-gap-2" style="margin-top:var(--pq-space-2);">
                                <PqInput Label="Name" Value="@item.Name" ValueChanged="@(v => item.Name = v ?? string.Empty)" Disabled="_isSaving" Required="true" />
                                <PqInput Label="Description" Value="@item.Description" ValueChanged="@(v => item.Description = v)" Disabled="_isSaving" />
                                <div class="pq-flex pq-gap-2" style="flex-wrap:wrap;">
                                    <div style="min-width:180px;flex:1;">
                                        <PqInput Label="Quantity" Type="number" Value="@item.Quantity" ValueChanged="@(v => item.Quantity = v ?? "0")" Disabled="_isSaving" />
                                    </div>
                                    <div style="min-width:180px;flex:1;">
                                        <PqInput Label="Unit" Value="@item.UnitOfMeasure" ValueChanged="@(v => item.UnitOfMeasure = v ?? string.Empty)" Disabled="_isSaving" />
                                    </div>
                                </div>
                                <PqTextarea Label="Technical Specifications" Value="@item.TechnicalSpecs" ValueChanged="@(v => item.TechnicalSpecs = v)" Disabled="_isSaving" />
                            </div>
                        </PqCard>
                    }
                </div>
            }

            @if (_errors.TryGetValue("LineItems", out string? lineItemError))
            {
                <p class="pq-caption" style="color:var(--pq-danger-text);margin-top:var(--pq-space-2);">@lineItemError</p>
            }
        </PqCard>

        <PqCard>
            <h2 class="pq-card-title">Documents</h2>
            <p class="pq-body-sm" style="margin-top:var(--pq-space-2);">
                Attach supporting RFQ files (specs, drawings, requirements). Max file size: 10 MB.
            </p>
            <div style="margin-top:var(--pq-space-3);">
                <InputFile OnChange="HandleFilesSelectedAsync" multiple />
            </div>

            @if (_pendingUploads.Count > 0)
            {
                <div style="margin-top:var(--pq-space-3);">
                    <p class="pq-body-sm"><strong>Pending uploads</strong></p>
                    <ul class="pq-body-sm" style="margin-top:var(--pq-space-2);padding-left:1rem;">
                        @foreach (PendingUpload pending in _pendingUploads)
                        {
                            <li>@pending.File.Name (@FormatFileSize(pending.File.Size))</li>
                        }
                    </ul>
                </div>
            }

            @if (_existingDocuments.Count > 0)
            {
                <div style="margin-top:var(--pq-space-3);">
                    <p class="pq-body-sm"><strong>Attached documents</strong></p>
                    <ul class="pq-body-sm" style="margin-top:var(--pq-space-2);padding-left:1rem;">
                        @foreach (Domain.Entities.RfqDocument doc in _existingDocuments)
                        {
                            <li style="display:flex;align-items:center;gap:var(--pq-space-2);flex-wrap:wrap;">
                                <a href="@doc.FilePath" target="_blank">@doc.FileName</a>
                                <span>(@FormatFileSize(doc.FileSize))</span>
                                <PqButton Variant="danger"
                                          Size="sm"
                                          OnClick="@(() => RemoveDocumentAsync(doc.Id))"
                                          Disabled="_isSaving">
                                    Remove
                                </PqButton>
                            </li>
                        }
                    </ul>
                </div>
            }
        </PqCard>

        <div style="display:flex;gap:var(--pq-space-2);justify-content:flex-end;flex-wrap:wrap;">
            <a href="/buyer/rfqs"><PqButton Variant="ghost">Cancel</PqButton></a>
            <PqButton Variant="secondary" OnClick="SaveDraftAsync" Loading="@(_isSaving && !_publishOnSave)">Save Draft</PqButton>
            <PqButton Variant="primary" OnClick="PublishAsync" Loading="@(_isSaving && _publishOnSave)">Save & Publish</PqButton>
        </div>
    </div>
}

@code {
    [Parameter] public Guid? RfqId { get; set; }

    private bool _isLoading = true;
    private bool _isSaving;
    private bool _publishOnSave;
    private Guid? _buyerId;
    private Guid? _editingRfqId;
    private string? _referenceNumber;
    private List<PendingUpload> _pendingUploads = [];
    private List<Domain.Entities.RfqDocument> _existingDocuments = [];

    private RfqForm _form = new();
    private List<LineItemForm> _lineItems = [];
    private List<PqSelect.SelectOption> _categoryOptions = [];
    private Dictionary<string, string> _errors = [];
    private const long MaxUploadBytes = 10 * 1024 * 1024;

    private bool IsEditMode => RfqId.HasValue;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            _buyerId = await GetCurrentBuyerIdAsync();
            if (!_buyerId.HasValue)
            {
                ToastService.ShowError("Unable to resolve current user.");
                return;
            }

            await LoadCategoriesAsync();
            AddLineItem();

            if (IsEditMode)
            {
                await LoadExistingRfqAsync(RfqId!.Value);
            }
            else
            {
                _referenceNumber = await UnitOfWork.Rfqs.GenerateReferenceNumberAsync();
                _form.SubmissionDeadline = DateTime.UtcNow.AddDays(7).ToString("yyyy-MM-ddTHH:mm");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message, "Failed to load RFQ form");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadCategoriesAsync()
    {
        IReadOnlyList<Domain.Entities.Category> categories = await UnitOfWork.Categories.GetActiveCategoriesAsync();
        _categoryOptions = categories
            .OrderBy(c => c.Name)
            .Select(c => new PqSelect.SelectOption
            {
                Value = c.Id.ToString(),
                Label = c.Name
            })
            .ToList();
    }

    private async Task LoadExistingRfqAsync(Guid rfqId)
    {
        Domain.Entities.Rfq? rfq = await UnitOfWork.Rfqs.GetWithDetailsAsync(rfqId);
        if (rfq == null || rfq.BuyerId != _buyerId || !rfq.CanBeEdited())
        {
            ToastService.ShowError("RFQ not found or cannot be edited.");
            NavigationManager.NavigateTo("/buyer/rfqs");
            return;
        }

        _editingRfqId = rfq.Id;
        _referenceNumber = rfq.ReferenceNumber;
        _existingDocuments = rfq.Documents
            .OrderBy(d => d.DisplayOrder)
            .ToList();
        _form = new RfqForm
        {
            Title = rfq.Title,
            Description = rfq.Description,
            CategoryId = rfq.CategoryId.ToString(),
            Currency = rfq.Currency,
            SubmissionDeadline = rfq.SubmissionDeadline.ToString("yyyy-MM-ddTHH:mm")
        };

        _lineItems = rfq.LineItems
            .OrderBy(li => li.DisplayOrder)
            .Select(li => new LineItemForm
            {
                Name = li.Name,
                Description = li.Description,
                Quantity = li.Quantity.ToString(System.Globalization.CultureInfo.InvariantCulture),
                UnitOfMeasure = li.UnitOfMeasure,
                TechnicalSpecs = li.TechnicalSpecs
            })
            .ToList();

        if (_lineItems.Count == 0)
        {
            AddLineItem();
        }
    }

    private void AddLineItem()
    {
        _lineItems.Add(new LineItemForm
        {
            Quantity = "1",
            UnitOfMeasure = "pcs"
        });
    }

    private void RemoveLineItem(int index)
    {
        if (index >= 0 && index < _lineItems.Count)
        {
            _lineItems.RemoveAt(index);
        }
    }

    private Task SaveDraftAsync()
    {
        _publishOnSave = false;
        return SaveAsync();
    }

    private Task PublishAsync()
    {
        _publishOnSave = true;
        return SaveAsync();
    }

    private async Task SaveAsync()
    {
        if (!_buyerId.HasValue)
        {
            ToastService.ShowError("Unable to resolve current user.");
            return;
        }

        _errors = ValidateForm(_publishOnSave);
        if (_errors.Count > 0)
        {
            return;
        }

        _isSaving = true;
        try
        {
            if (_editingRfqId.HasValue)
            {
                await UpdateExistingRfqAsync(_editingRfqId.Value, _buyerId.Value);
                await SavePendingDocumentsAsync(_editingRfqId.Value, _buyerId.Value);

                await AuditLogService.LogRfqActionAsync(
                    _editingRfqId.Value,
                    _buyerId.Value,
                    "RfqUpdated",
                    "Rfq",
                    _editingRfqId.Value,
                    details: _publishOnSave ? "RFQ updated and published by buyer." : "RFQ draft updated by buyer.");
                ToastService.ShowSuccess(_publishOnSave ? "RFQ published successfully." : "RFQ draft updated.");
            }
            else
            {
                Guid newRfqId = await CreateRfqAsync(_buyerId.Value);
                await SavePendingDocumentsAsync(newRfqId, _buyerId.Value);

                await AuditLogService.LogRfqActionAsync(
                    newRfqId,
                    _buyerId.Value,
                    "RfqCreated",
                    "Rfq",
                    newRfqId,
                    details: _publishOnSave ? "RFQ created and published by buyer." : "RFQ draft created by buyer.");
                ToastService.ShowSuccess(_publishOnSave ? "RFQ created and published." : "RFQ draft created.");
            }

            NavigationManager.NavigateTo("/buyer/rfqs");
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message, "Failed to save RFQ");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task<Guid> CreateRfqAsync(Guid buyerId)
    {
        string reference = _referenceNumber ?? await UnitOfWork.Rfqs.GenerateReferenceNumberAsync();
        DateTime submissionDeadline = DateTime.Parse(_form.SubmissionDeadline, null, System.Globalization.DateTimeStyles.AssumeUniversal).ToUniversalTime();
        Guid categoryId = Guid.Parse(_form.CategoryId);

        Domain.Entities.Rfq rfq = new()
        {
            Id = Guid.NewGuid(),
            ReferenceNumber = reference,
            Title = _form.Title.Trim(),
            Description = string.IsNullOrWhiteSpace(_form.Description) ? null : _form.Description.Trim(),
            CategoryId = categoryId,
            Currency = _form.Currency.Trim().ToUpperInvariant(),
            SubmissionDeadline = submissionDeadline,
            Status = _publishOnSave ? Domain.Enums.RfqStatus.Published : Domain.Enums.RfqStatus.Draft,
            BuyerId = buyerId,
            PublishedAt = _publishOnSave ? DateTime.UtcNow : null,
            CreatedAt = DateTime.UtcNow
        };

        foreach (LineItemForm item in _lineItems.Where(IsLineItemFilled).Select((x, i) => x with { DisplayOrder = i + 1 }))
        {
            rfq.LineItems.Add(new Domain.Entities.LineItem
            {
                Id = Guid.NewGuid(),
                RfqId = rfq.Id,
                Name = item.Name.Trim(),
                Description = string.IsNullOrWhiteSpace(item.Description) ? null : item.Description.Trim(),
                Quantity = ParseQuantity(item.Quantity),
                UnitOfMeasure = item.UnitOfMeasure.Trim(),
                TechnicalSpecs = string.IsNullOrWhiteSpace(item.TechnicalSpecs) ? null : item.TechnicalSpecs.Trim(),
                DisplayOrder = item.DisplayOrder,
                CreatedAt = DateTime.UtcNow
            });
        }

        await UnitOfWork.Rfqs.AddAsync(rfq);
        await UnitOfWork.SaveChangesAsync();
        return rfq.Id;
    }

    private async Task UpdateExistingRfqAsync(Guid rfqId, Guid buyerId)
    {
        Domain.Entities.Rfq? rfq = await UnitOfWork.Rfqs.GetWithDetailsAsync(rfqId);
        if (rfq == null || rfq.BuyerId != buyerId || !rfq.CanBeEdited())
        {
            throw new InvalidOperationException("RFQ not found or cannot be edited.");
        }

        rfq.Title = _form.Title.Trim();
        rfq.Description = string.IsNullOrWhiteSpace(_form.Description) ? null : _form.Description.Trim();
        rfq.CategoryId = Guid.Parse(_form.CategoryId);
        rfq.Currency = _form.Currency.Trim().ToUpperInvariant();
        rfq.SubmissionDeadline = DateTime.Parse(_form.SubmissionDeadline, null, System.Globalization.DateTimeStyles.AssumeUniversal).ToUniversalTime();
        rfq.Status = _publishOnSave ? Domain.Enums.RfqStatus.Published : Domain.Enums.RfqStatus.Draft;
        rfq.PublishedAt ??= _publishOnSave ? DateTime.UtcNow : null;

        rfq.LineItems.Clear();
        foreach (LineItemForm item in _lineItems.Where(IsLineItemFilled).Select((x, i) => x with { DisplayOrder = i + 1 }))
        {
            rfq.LineItems.Add(new Domain.Entities.LineItem
            {
                Id = Guid.NewGuid(),
                RfqId = rfq.Id,
                Name = item.Name.Trim(),
                Description = string.IsNullOrWhiteSpace(item.Description) ? null : item.Description.Trim(),
                Quantity = ParseQuantity(item.Quantity),
                UnitOfMeasure = item.UnitOfMeasure.Trim(),
                TechnicalSpecs = string.IsNullOrWhiteSpace(item.TechnicalSpecs) ? null : item.TechnicalSpecs.Trim(),
                DisplayOrder = item.DisplayOrder,
                CreatedAt = DateTime.UtcNow
            });
        }

        UnitOfWork.Rfqs.Update(rfq);
        await UnitOfWork.SaveChangesAsync();

        _existingDocuments = (await UnitOfWork.Rfqs.GetDocumentsAsync(rfqId)).ToList();
    }

    private async Task HandleFilesSelectedAsync(InputFileChangeEventArgs args)
    {
        IReadOnlyList<IBrowserFile> files = args.GetMultipleFiles();
        foreach (IBrowserFile file in files)
        {
            if (file.Size <= 0)
            {
                continue;
            }

            if (file.Size > MaxUploadBytes)
            {
                ToastService.ShowError($"{file.Name} exceeds 10 MB and was skipped.");
                continue;
            }

            if (!DocumentFileValidation.TryGetAllowedContentType(file.Name, out _))
            {
                ToastService.ShowError($"{file.Name} has an unsupported file type.");
                continue;
            }

            _pendingUploads.Add(new PendingUpload(file));
        }
    }

    private async Task SavePendingDocumentsAsync(Guid rfqId, Guid buyerId)
    {
        if (_pendingUploads.Count == 0)
        {
            return;
        }

        string targetDir = GetRfqStorageDirectory(rfqId);
        Directory.CreateDirectory(targetDir);

        int displayOrder = _existingDocuments.Count > 0 ? _existingDocuments.Max(d => d.DisplayOrder) + 1 : 1;
        List<Domain.Entities.RfqDocument> newDocuments = [];

        foreach (PendingUpload upload in _pendingUploads)
        {
            IBrowserFile file = upload.File;
            string extension = Path.GetExtension(file.Name);
            string storedFileName = $"{Guid.NewGuid():N}{extension}";
            string physicalPath = Path.Combine(targetDir, storedFileName);
            if (!DocumentFileValidation.TryGetAllowedContentType(file.Name, out string safeContentType))
            {
                continue;
            }

            await using Stream sourceStream = file.OpenReadStream(MaxUploadBytes);
            await using FileStream destinationStream = File.Create(physicalPath);
            await sourceStream.CopyToAsync(destinationStream);

            Guid documentId = Guid.NewGuid();
            string relativeFilePath = $"/api/v1/documents/rfq/{documentId}";
            Domain.Entities.RfqDocument document = new()
            {
                Id = documentId,
                RfqId = rfqId,
                FileName = DocumentFileValidation.SanitizeFileName(file.Name),
                StoredFileName = storedFileName,
                ContentType = safeContentType,
                FileSize = file.Size,
                FilePath = relativeFilePath,
                DisplayOrder = displayOrder++,
                UploadedById = buyerId,
                UploadedAt = DateTime.UtcNow,
                CreatedAt = DateTime.UtcNow
            };

            newDocuments.Add(document);
        }

        if (newDocuments.Count > 0)
        {
            await UnitOfWork.Rfqs.AddDocumentsAsync(newDocuments);
            await UnitOfWork.SaveChangesAsync();
            _existingDocuments.AddRange(newDocuments);

            await AuditLogService.LogRfqActionAsync(
                rfqId,
                buyerId,
                "RfqDocumentsUploaded",
                "RfqDocument",
                entityId: null,
                details: $"Uploaded {newDocuments.Count} document(s): {string.Join(", ", newDocuments.Select(d => d.FileName))}.");
        }

        _pendingUploads.Clear();
    }

    private async Task RemoveDocumentAsync(Guid documentId)
    {
        Domain.Entities.RfqDocument? existing = await UnitOfWork.Rfqs.GetDocumentByIdAsync(documentId);
        if (existing == null)
        {
            return;
        }

        UnitOfWork.Rfqs.RemoveDocument(existing);
        await UnitOfWork.SaveChangesAsync();

        string physicalPath = Path.Combine(GetRfqStorageDirectory(existing.RfqId), existing.StoredFileName);
        if (File.Exists(physicalPath))
        {
            File.Delete(physicalPath);
        }

        _existingDocuments = _existingDocuments
            .Where(d => d.Id != documentId)
            .OrderBy(d => d.DisplayOrder)
            .ToList();

        if (_buyerId.HasValue)
        {
            await AuditLogService.LogRfqActionAsync(
                existing.RfqId,
                _buyerId.Value,
                "RfqDocumentRemoved",
                "RfqDocument",
                existing.Id,
                details: $"Removed RFQ document {existing.FileName}.");
        }

        ToastService.ShowSuccess("Document removed.");
    }

    private Dictionary<string, string> ValidateForm(bool requireLineItems)
    {
        Dictionary<string, string> errors = [];

        if (string.IsNullOrWhiteSpace(_form.Title))
        {
            errors[nameof(_form.Title)] = "Title is required.";
        }

        if (!Guid.TryParse(_form.CategoryId, out _))
        {
            errors[nameof(_form.CategoryId)] = "Category is required.";
        }

        if (string.IsNullOrWhiteSpace(_form.SubmissionDeadline) ||
            !DateTime.TryParse(_form.SubmissionDeadline, out DateTime parsedDeadline) ||
            parsedDeadline.ToUniversalTime() <= DateTime.UtcNow)
        {
            errors[nameof(_form.SubmissionDeadline)] = "Submission deadline must be in the future.";
        }

        List<LineItemForm> validLineItems = _lineItems.Where(IsLineItemFilled).ToList();
        if (requireLineItems && validLineItems.Count == 0)
        {
            errors["LineItems"] = "Add at least one valid line item before publishing.";
        }
        else if (validLineItems.Any(i => ParseQuantity(i.Quantity) <= 0))
        {
            errors["LineItems"] = "All line item quantities must be greater than zero.";
        }

        return errors;
    }

    private static bool IsLineItemFilled(LineItemForm item)
    {
        return !string.IsNullOrWhiteSpace(item.Name) && !string.IsNullOrWhiteSpace(item.UnitOfMeasure);
    }

    private static decimal ParseQuantity(string? value)
    {
        if (decimal.TryParse(value, System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out decimal parsed))
        {
            return parsed;
        }

        if (decimal.TryParse(value, out parsed))
        {
            return parsed;
        }

        return 0m;
    }

    private static string FormatFileSize(long bytes)
    {
        string[] sizes = ["B", "KB", "MB", "GB"];
        double size = bytes;
        int order = 0;
        while (size >= 1024 && order < sizes.Length - 1)
        {
            order++;
            size /= 1024;
        }

        return $"{size:0.##} {sizes[order]}";
    }

    private string GetPrivateUploadRoot()
    {
        return Path.Combine(HostEnvironment.ContentRootPath, "App_Data", "uploads");
    }

    private string GetRfqStorageDirectory(Guid rfqId)
    {
        return Path.Combine(GetPrivateUploadRoot(), "rfqs", rfqId.ToString("N"));
    }

    private async Task<Guid?> GetCurrentBuyerIdAsync()
    {
        AuthenticationState authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        string? userIdClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        return Guid.TryParse(userIdClaim, out Guid parsed) ? parsed : null;
    }

    private sealed class RfqForm
    {
        public string Title { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string CategoryId { get; set; } = string.Empty;
        public string Currency { get; set; } = "USD";
        public string SubmissionDeadline { get; set; } = string.Empty;
    }

    private sealed record LineItemForm
    {
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string Quantity { get; set; } = "1";
        public string UnitOfMeasure { get; set; } = string.Empty;
        public string? TechnicalSpecs { get; set; }
        public int DisplayOrder { get; set; }
    }

    private sealed record PendingUpload(IBrowserFile File);
}
