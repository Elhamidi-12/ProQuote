@page "/buyer/dashboard"
@rendermode InteractiveServer
@layout BuyerLayout
@attribute [Authorize(Roles = ApplicationRoles.Buyer)]

<PageTitle>Buyer Dashboard - ProQuote</PageTitle>

<div class="pq-flex pq-flex-col pq-gap-4">
    <div class="pq-flex pq-justify-between pq-items-center">
        <h1 class="pq-section-title">Buyer Dashboard</h1>
        <a href="/buyer/rfqs/create"><PqButton Variant="primary">Create RFQ</PqButton></a>
    </div>

    <div class="dashboard-grid">
        <PqStatCard Title="Draft RFQs" Value="@_stats.DraftRfqs.ToString()" />
        <PqStatCard Title="Active RFQs" Value="@_stats.ActiveRfqs.ToString()" />
        <PqStatCard Title="Pending Quotes" Value="@_stats.PendingQuotes.ToString()" />
        <PqStatCard Title="Awarded" Value="@_stats.AwardedRfqs.ToString()" />
    </div>

    <PqCard>
        <h2 class="pq-card-title">My Active RFQs</h2>
        @if (_activeRfqs.Count == 0)
        {
            <p class="pq-body-sm" style="margin-top:var(--pq-space-2);">No active RFQs.</p>
        }
        else
        {
            <div style="margin-top:var(--pq-space-3);">
                <PqTable Headers="_headers">
                    @foreach (var rfq in _activeRfqs)
                    {
                        <tr>
                            <td>@rfq.ReferenceNumber</td>
                            <td>@rfq.Title</td>
                            <td>@rfq.SubmissionDeadline.ToString("MMM dd, yyyy")</td>
                            <td><PqBadge Variant="published">@rfq.Quotes.Count quote(s)</PqBadge></td>
                        </tr>
                    }
                </PqTable>
            </div>
        }
    </PqCard>
</div>

@code {
    private DashboardStats _stats = new();
    private List<Domain.Entities.Rfq> _activeRfqs = [];

    private readonly List<PqTable.TableColumn> _headers =
    [
        new() { Label = "Reference", Field = "ref" },
        new() { Label = "Title", Field = "title" },
        new() { Label = "Deadline", Field = "deadline" },
        new() { Label = "Quotes", Field = "quotes" }
    ];

    [Inject] private IUnitOfWork UnitOfWork { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthState { get; set; } = default!;

    protected override async Task OnInitializedAsync() => await LoadDashboardDataAsync();

    private async Task LoadDashboardDataAsync()
    {
        AuthenticationState authState = await AuthState;
        string? userIdString = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (!Guid.TryParse(userIdString, out Guid userId)) return;

        IReadOnlyList<Domain.Entities.Rfq> allRfqs = await UnitOfWork.Rfqs.GetByBuyerIdAsync(userId);
        _stats.DraftRfqs = allRfqs.Count(r => r.Status == Domain.Enums.RfqStatus.Draft);
        _stats.ActiveRfqs = allRfqs.Count(r => r.Status == Domain.Enums.RfqStatus.Published);
        _stats.AwardedRfqs = allRfqs.Count(r => r.Status == Domain.Enums.RfqStatus.Awarded);
        _stats.PendingQuotes = allRfqs.Where(r => r.Status == Domain.Enums.RfqStatus.Published).Sum(r => r.Quotes.Count);
        _activeRfqs = allRfqs.Where(r => r.Status == Domain.Enums.RfqStatus.Published).Take(5).ToList();
    }

    private class DashboardStats
    {
        public int DraftRfqs { get; set; }
        public int ActiveRfqs { get; set; }
        public int PendingQuotes { get; set; }
        public int AwardedRfqs { get; set; }
    }
}
