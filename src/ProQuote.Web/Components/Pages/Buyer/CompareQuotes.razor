@page "/buyer/quotes/compare"
@rendermode InteractiveServer
@layout BuyerLayout
@attribute [Authorize(Roles = ApplicationRoles.Buyer)]
@using System.Security.Claims
@using System.Globalization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using ProQuote.Application.DTOs.Quotes
@using ProQuote.Application.UseCases.BuyerRfqs.Scoring.SetQuoteScoringTemplate
@implements IDisposable
@inject IBuyerQuoteManagementService BuyerQuoteManagementService
@inject ISetQuoteScoringTemplateUseCase SetQuoteScoringTemplateUseCase
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Compare Quotes - ProQuote</PageTitle>

<h1 class="pq-section-title">Compare Quotes</h1>
@if (_isLoading)
{
    <PqCard>
        <p class="pq-body-sm">Loading comparison data...</p>
    </PqCard>
}
else if (_comparison is null)
{
    <PqCard>
        <p class="pq-body-sm">Select an RFQ from <a href="/buyer/quotes">Received Quotes</a> to compare.</p>
    </PqCard>
}
else if (_comparison.Quotes.Count == 0)
{
    <PqCard>
        <p class="pq-body-sm">No comparable quotes available for this RFQ.</p>
    </PqCard>
}
else
{
    <div class="pq-flex pq-flex-col pq-gap-4">
        <PqCard>
            <div class="pq-flex pq-justify-between pq-items-center" style="flex-wrap:wrap;gap:var(--pq-space-2);">
                <div>
                    <h2 class="pq-card-title">@_comparison.ReferenceNumber - @_comparison.Title</h2>
                    <p class="pq-body-sm">Deadline: @_comparison.SubmissionDeadline.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</p>
                </div>
                <div class="pq-flex pq-gap-2" style="flex-wrap:wrap;">
                    <PqBadge Variant="@GetRfqStatusBadgeVariant(_comparison.Status)">@_comparison.Status</PqBadge>
                    <PqBadge Variant="published">Currency: @_comparison.Currency</PqBadge>
                </div>
            </div>
        </PqCard>

        <PqCard>
            <h2 class="pq-card-title">Scoring Template</h2>
            <p class="pq-body-sm">Adjust weights for ranking. Weights auto-normalize to 100% when saved.</p>
            <div class="pq-flex pq-gap-3" style="flex-wrap:wrap;align-items:flex-end;margin-top:var(--pq-space-2);">
                <div style="min-width:160px;">
                    <PqInput Label="Price Weight"
                             Type="number"
                             Value="@_priceWeightInput"
                             ValueChanged="OnPriceWeightChanged"
                             Disabled="_isSavingTemplate" />
                </div>
                <div style="min-width:160px;">
                    <PqInput Label="Lead Time Weight"
                             Type="number"
                             Value="@_leadTimeWeightInput"
                             ValueChanged="OnLeadTimeWeightChanged"
                             Disabled="_isSavingTemplate" />
                </div>
                <div style="min-width:160px;">
                    <PqInput Label="Coverage Weight"
                             Type="number"
                             Value="@_coverageWeightInput"
                             ValueChanged="OnCoverageWeightChanged"
                             Disabled="_isSavingTemplate" />
                </div>
                <PqButton Variant="primary" OnClick="SaveTemplateAsync" Loading="_isSavingTemplate">Save Weights</PqButton>
            </div>
        </PqCard>

        @if (RecommendedQuote is not null)
        {
            <PqCard>
                <div class="pq-flex pq-justify-between pq-items-center" style="flex-wrap:wrap;gap:var(--pq-space-2);">
                    <h2 class="pq-card-title">Award Decision Summary</h2>
                    <PqBadge Variant="primary">Rank #1</PqBadge>
                </div>
                <p class="pq-body-sm" style="margin-top:var(--pq-space-1);">
                    Recommended supplier:
                    <strong>@RecommendedQuote.SupplierName</strong>
                </p>
                <div class="pq-flex pq-gap-2" style="flex-wrap:wrap;margin-top:var(--pq-space-2);">
                    <PqBadge Variant="published">Price Score: @RecommendedQuote.Score.PriceScore.ToString("N2")</PqBadge>
                    <PqBadge Variant="pending">Lead-Time Score: @RecommendedQuote.Score.LeadTimeScore.ToString("N2")</PqBadge>
                    <PqBadge Variant="secondary">Coverage Score: @RecommendedQuote.Score.CoverageScore.ToString("N2")</PqBadge>
                    <PqBadge Variant="awarded">Final Score: @RecommendedQuote.Score.CompositeScore.ToString("N2")</PqBadge>
                </div>
                <p class="pq-body-sm" style="margin-top:var(--pq-space-2);">
                    Weights:
                    Price @_comparison.ScoringTemplate.PriceWeight.ToString("N2")%,
                    Lead Time @_comparison.ScoringTemplate.LeadTimeWeight.ToString("N2")%,
                    Coverage @_comparison.ScoringTemplate.CoverageWeight.ToString("N2")%.
                </p>
            </PqCard>
        }

        <PqCard>
            <PqTable Headers="_headers">
                @foreach (BuyerQuoteComparisonItemDto quote in _comparison.Quotes)
                {
                    <tr>
                        <td>@quote.SupplierName</td>
                        <td>@quote.TotalAmount.ToString("N2") @_comparison.Currency</td>
                        <td>@quote.LeadTimeDays days</td>
                        <td>@quote.Score.CompositeScore.ToString("N2")</td>
                        <td>@quote.ValidUntil.ToLocalTime().ToString("MMM dd, yyyy")</td>
                        <td><PqBadge Variant="@GetQuoteBadgeVariant(quote)">@GetQuoteLabel(quote)</PqBadge></td>
                        <td>
                            <PqButton Variant="ghost" Size="sm" OnClick="@(() => SelectQuote(quote.QuoteId))">Details</PqButton>
                            @if (!IsAwardedRfq && !quote.IsAwarded)
                            {
                                <PqButton Variant="primary"
                                          Size="sm"
                                          OnClick="@(() => AwardQuoteAsync(quote.QuoteId))"
                                          Loading="@(_isAwarding && _awardingQuoteId == quote.QuoteId)">
                                    Award
                                </PqButton>
                            }
                        </td>
                    </tr>
                }
            </PqTable>
        </PqCard>

        @if (SelectedQuote is not null)
        {
            <PqCard>
                <div class="pq-flex pq-justify-between pq-items-center" style="flex-wrap:wrap;gap:var(--pq-space-2);">
                    <h2 class="pq-card-title">Quote Details - @SelectedQuote.SupplierName</h2>
                    <PqBadge Variant="@GetQuoteBadgeVariant(SelectedQuote)">@GetQuoteLabel(SelectedQuote)</PqBadge>
                </div>
                <div class="pq-flex pq-gap-3" style="flex-wrap:wrap;margin-top:var(--pq-space-2);">
                    <PqBadge Variant="pending">Lead Time: @SelectedQuote.LeadTimeDays days</PqBadge>
                    <PqBadge Variant="published">Valid Until: @SelectedQuote.ValidUntil.ToLocalTime().ToString("MMM dd, yyyy")</PqBadge>
                    <PqBadge Variant="awarded">Total: @SelectedQuote.TotalAmount.ToString("N2") @_comparison.Currency</PqBadge>
                    <PqBadge Variant="primary">Score: @SelectedQuote.Score.CompositeScore.ToString("N2")</PqBadge>
                </div>

                @if (!string.IsNullOrWhiteSpace(SelectedQuote.PaymentTerms))
                {
                    <p class="pq-body-sm" style="margin-top:var(--pq-space-2);"><strong>Payment Terms:</strong> @SelectedQuote.PaymentTerms</p>
                }
                @if (!string.IsNullOrWhiteSpace(SelectedQuote.Notes))
                {
                    <p class="pq-body-sm" style="margin-top:var(--pq-space-2);"><strong>Supplier Notes:</strong> @SelectedQuote.Notes</p>
                }
                @if (!string.IsNullOrWhiteSpace(SelectedQuote.BuyerNotes))
                {
                    <p class="pq-body-sm" style="margin-top:var(--pq-space-2);"><strong>Buyer Notes:</strong> @SelectedQuote.BuyerNotes</p>
                }
                @if (SelectedQuote.Documents.Count > 0)
                {
                    <div style="margin-top:var(--pq-space-3);">
                        <p class="pq-body-sm"><strong>Supporting Documents</strong></p>
                        <ul class="pq-body-sm" style="margin-top:var(--pq-space-2);padding-left:1rem;">
                            @foreach (BuyerQuoteComparisonDocumentDto doc in SelectedQuote.Documents)
                            {
                                <li>
                                    <a href="@doc.FilePath" target="_blank">@doc.FileName</a>
                                    <span> (@FormatFileSize(doc.FileSize))</span>
                                </li>
                            }
                        </ul>
                    </div>
                }

                <div style="margin-top:var(--pq-space-3);">
                    <PqTable Headers="_priceHeaders">
                        @foreach (BuyerQuoteComparisonLineItemDto lineItem in _comparison.RfqLineItems)
                        {
                            BuyerQuoteComparisonPriceDto? price = SelectedQuote.Prices.FirstOrDefault(p => p.LineItemId == lineItem.LineItemId);
                            <tr>
                                <td>@lineItem.Name</td>
                                <td>@lineItem.Quantity.ToString("N2") @lineItem.UnitOfMeasure</td>
                                <td>@((price?.UnitPrice ?? 0m).ToString("N2")) @_comparison.Currency</td>
                                <td>@((price?.TotalPrice ?? 0m).ToString("N2")) @_comparison.Currency</td>
                            </tr>
                        }
                    </PqTable>
                </div>
            </PqCard>
        }
    </div>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "rfqId")]
    public Guid? RfqId { get; set; }

    private bool _isLoading = true;
    private bool _isAwarding;
    private bool _isSavingTemplate;
    private Guid? _awardingQuoteId;
    private Guid? _buyerUserId;
    private Guid? _selectedQuoteId;
    private BuyerQuoteComparisonDto? _comparison;
    private QuoteScoringTemplateDto _templateModel = new();
    private string _priceWeightInput = "60";
    private string _leadTimeWeightInput = "25";
    private string _coverageWeightInput = "15";

    private readonly List<PqTable.TableColumn> _headers =
    [
        new() { Label = "Supplier", Field = "supplier" },
        new() { Label = "Total", Field = "total" },
        new() { Label = "Lead Time", Field = "leadTime" },
        new() { Label = "Score", Field = "score" },
        new() { Label = "Valid Until", Field = "validUntil" },
        new() { Label = "Status", Field = "status" },
        new() { Label = "Actions", Field = "actions", Width = "220px" }
    ];

    private readonly List<PqTable.TableColumn> _priceHeaders =
    [
        new() { Label = "Line Item", Field = "lineItem" },
        new() { Label = "Requested Qty", Field = "quantity" },
        new() { Label = "Unit Price", Field = "unitPrice" },
        new() { Label = "Line Total", Field = "lineTotal" }
    ];

    private BuyerQuoteComparisonItemDto? SelectedQuote =>
        _comparison?.Quotes.FirstOrDefault(q => q.QuoteId == _selectedQuoteId);

    private BuyerQuoteComparisonItemDto? RecommendedQuote => _comparison?.Quotes.FirstOrDefault();

    private bool IsAwardedRfq => _comparison?.Status == Domain.Enums.RfqStatus.Awarded;

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        await LoadAsync();
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        string current = NavigationManager.ToBaseRelativePath(e.Location);
        if (current.StartsWith("buyer/quotes/compare", StringComparison.OrdinalIgnoreCase))
        {
            await InvokeAsync(async () =>
            {
                await LoadAsync();
                StateHasChanged();
            });
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            _buyerUserId ??= await GetCurrentUserIdAsync();
            if (!_buyerUserId.HasValue)
            {
                ToastService.ShowError("Unable to resolve current user.");
                return;
            }

            if (!RfqId.HasValue)
            {
                _comparison = null;
                _selectedQuoteId = null;
                return;
            }

            _comparison = await BuyerQuoteManagementService.GetComparisonAsync(_buyerUserId.Value, RfqId.Value);
            if (_comparison == null)
            {
                ToastService.ShowError("RFQ comparison was not found.");
                return;
            }

            _selectedQuoteId = _comparison.Quotes
                .OrderByDescending(q => q.IsAwarded || q.Status == Domain.Enums.QuoteStatus.Awarded)
                .ThenByDescending(q => q.Score.CompositeScore)
                .ThenBy(q => q.TotalAmount)
                .Select(q => (Guid?)q.QuoteId)
                .FirstOrDefault();

            _templateModel = new QuoteScoringTemplateDto
            {
                PriceWeight = _comparison.ScoringTemplate.PriceWeight,
                LeadTimeWeight = _comparison.ScoringTemplate.LeadTimeWeight,
                CoverageWeight = _comparison.ScoringTemplate.CoverageWeight
            };
            SyncWeightInputsFromTemplate();
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message, "Failed to load quote comparison");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void SelectQuote(Guid quoteId)
    {
        _selectedQuoteId = quoteId;
    }

    private async Task AwardQuoteAsync(Guid quoteId)
    {
        if (!_buyerUserId.HasValue || _comparison is null)
        {
            ToastService.ShowError("Unable to resolve award context.");
            return;
        }

        BuyerQuoteComparisonItemDto? quoteToAward = _comparison.Quotes.FirstOrDefault(q => q.QuoteId == quoteId);
        if (quoteToAward is null)
        {
            ToastService.ShowError("Unable to resolve selected quote.");
            return;
        }

        _isAwarding = true;
        _awardingQuoteId = quoteId;
        try
        {
            string decisionSummary = BuildAwardDecisionSummary(quoteToAward);
            AwardQuoteResponse result = await BuyerQuoteManagementService.AwardQuoteAsync(
                _buyerUserId.Value,
                _comparison.RfqId,
                quoteId,
                decisionSummary);

            if (!result.Succeeded)
            {
                ToastService.ShowError(result.ErrorMessage ?? "Unable to award quote.");
                return;
            }

            ToastService.ShowSuccess("Quote awarded successfully.");
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message, "Failed to award quote");
        }
        finally
        {
            _isAwarding = false;
            _awardingQuoteId = null;
        }
    }

    private string BuildAwardDecisionSummary(BuyerQuoteComparisonItemDto quote)
    {
        int rank = (_comparison?.Quotes.FindIndex(q => q.QuoteId == quote.QuoteId) ?? -1) + 1;
        string rankLabel = rank > 0 ? $"Rank #{rank}" : "Rank unknown";

        return string.Format(
            CultureInfo.InvariantCulture,
            "Awarded {0} ({1}) with Final Score {2:N2} [Price {3:N2}, Lead Time {4:N2}, Coverage {5:N2}], Total {6:N2} {7}, Lead Time {8} days; Weights Price {9:N2}%, Lead Time {10:N2}%, Coverage {11:N2}%.",
            quote.SupplierName,
            rankLabel,
            quote.Score.CompositeScore,
            quote.Score.PriceScore,
            quote.Score.LeadTimeScore,
            quote.Score.CoverageScore,
            quote.TotalAmount,
            _comparison?.Currency ?? "USD",
            quote.LeadTimeDays,
            _comparison?.ScoringTemplate.PriceWeight ?? 0m,
            _comparison?.ScoringTemplate.LeadTimeWeight ?? 0m,
            _comparison?.ScoringTemplate.CoverageWeight ?? 0m);
    }

    private Task OnPriceWeightChanged(string? value)
    {
        _priceWeightInput = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnLeadTimeWeightChanged(string? value)
    {
        _leadTimeWeightInput = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnCoverageWeightChanged(string? value)
    {
        _coverageWeightInput = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private async Task SaveTemplateAsync()
    {
        if (!_buyerUserId.HasValue || _comparison is null)
        {
            ToastService.ShowError("Unable to resolve scoring context.");
            return;
        }

        _isSavingTemplate = true;
        try
        {
            _templateModel.PriceWeight = ParseWeight(_priceWeightInput);
            _templateModel.LeadTimeWeight = ParseWeight(_leadTimeWeightInput);
            _templateModel.CoverageWeight = ParseWeight(_coverageWeightInput);

            SetQuoteScoringTemplateResponse response = await SetQuoteScoringTemplateUseCase.ExecuteAsync(
                new SetQuoteScoringTemplateCommand(
                    _buyerUserId.Value,
                    _comparison.RfqId,
                    _templateModel.PriceWeight,
                    _templateModel.LeadTimeWeight,
                    _templateModel.CoverageWeight));

            if (!response.Succeeded)
            {
                ToastService.ShowError(response.ErrorMessage ?? "Unable to save scoring template.");
                return;
            }

            _templateModel = response.Template;
            SyncWeightInputsFromTemplate();
            ToastService.ShowSuccess("Scoring template saved.");
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message, "Failed to save scoring template");
        }
        finally
        {
            _isSavingTemplate = false;
        }
    }

    private async Task<Guid?> GetCurrentUserIdAsync()
    {
        AuthenticationState authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        string? userIdClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        return Guid.TryParse(userIdClaim, out Guid parsed) ? parsed : null;
    }

    private static string GetRfqStatusBadgeVariant(Domain.Enums.RfqStatus status)
    {
        return status switch
        {
            Domain.Enums.RfqStatus.QuotesReceived => "pending",
            Domain.Enums.RfqStatus.UnderEvaluation => "pending",
            Domain.Enums.RfqStatus.Awarded => "awarded",
            _ => "default"
        };
    }

    private static string GetQuoteBadgeVariant(BuyerQuoteComparisonItemDto quote)
    {
        if (quote.IsAwarded || quote.Status == Domain.Enums.QuoteStatus.Awarded)
        {
            return "awarded";
        }

        return quote.Status switch
        {
            Domain.Enums.QuoteStatus.Submitted => "published",
            Domain.Enums.QuoteStatus.UnderReview => "pending",
            Domain.Enums.QuoteStatus.Rejected => "expired",
            Domain.Enums.QuoteStatus.Withdrawn => "cancelled",
            _ => "default"
        };
    }

    private static string GetQuoteLabel(BuyerQuoteComparisonItemDto quote)
    {
        if (quote.IsAwarded || quote.Status == Domain.Enums.QuoteStatus.Awarded)
        {
            return "Awarded";
        }

        return quote.Status.ToString();
    }

    private static string FormatFileSize(long bytes)
    {
        string[] sizes = ["B", "KB", "MB", "GB"];
        double size = bytes;
        int order = 0;
        while (size >= 1024 && order < sizes.Length - 1)
        {
            order++;
            size /= 1024;
        }

        return $"{size:0.##} {sizes[order]}";
    }

    private void SyncWeightInputsFromTemplate()
    {
        _priceWeightInput = _templateModel.PriceWeight.ToString("0.##", CultureInfo.InvariantCulture);
        _leadTimeWeightInput = _templateModel.LeadTimeWeight.ToString("0.##", CultureInfo.InvariantCulture);
        _coverageWeightInput = _templateModel.CoverageWeight.ToString("0.##", CultureInfo.InvariantCulture);
    }

    private static decimal ParseWeight(string? value)
    {
        if (decimal.TryParse(value, NumberStyles.Number, CultureInfo.InvariantCulture, out decimal parsedInvariant))
        {
            return parsedInvariant;
        }

        if (decimal.TryParse(value, NumberStyles.Number, CultureInfo.CurrentCulture, out decimal parsedCurrent))
        {
            return parsedCurrent;
        }

        return 0m;
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
