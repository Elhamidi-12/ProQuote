@page "/login"
@layout AuthLayout
@rendermode InteractiveServer
@inject IAuthService AuthService
@inject CustomAuthStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Login - ProQuote</PageTitle>

<div style="max-width:520px;margin:var(--pq-space-10) auto;">
    <PqCard>
        <h1 class="pq-section-title">Sign In</h1>
        <EditForm Model="_loginRequest" OnValidSubmit="HandleLoginAsync" FormName="loginForm">
            <DataAnnotationsValidator />
            <div class="pq-flex pq-flex-col pq-gap-3" style="margin-top:var(--pq-space-4);">
                <PqInput Label="Email" Type="email" Value="@_loginRequest.Email" ValueChanged="@(v => _loginRequest.Email = v ?? string.Empty)" Disabled="_isLoading" />
                <PqInput Label="Password" Type="password" Value="@_loginRequest.Password" ValueChanged="@(v => _loginRequest.Password = v ?? string.Empty)" Disabled="_isLoading" />
                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <p class="pq-caption" style="color:var(--pq-danger-text)">@_errorMessage</p>
                }
                <PqButton Variant="primary" Type="submit" Loading="_isLoading" FullWidth="true">Sign In</PqButton>
            </div>
        </EditForm>
        <div style="margin-top:var(--pq-space-4);display:flex;gap:var(--pq-space-2);flex-wrap:wrap;">
            <a href="/register">Register as Buyer</a>
            <a href="/register/supplier">Register as Supplier</a>
            <a href="/showcase">UI Showcase</a>
        </div>
    </PqCard>
</div>

@code {
    private LoginRequest _loginRequest = new();
    private bool _isLoading;
    private string? _errorMessage;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private async Task HandleLoginAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            AuthResponse response = await AuthService.LoginAsync(_loginRequest);
            if (response.Succeeded)
            {
                await AuthStateProvider.MarkUserAsAuthenticatedAsync(response);
                ToastService.ShowSuccess($"Welcome back, {response.User?.FirstName}!");
                NavigationManager.NavigateTo(GetRedirectUrl(response.User!), forceLoad: false);
            }
            else
            {
                _errorMessage = response.ErrorMessage ?? "Login failed. Please try again.";
                ToastService.ShowError(_errorMessage);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "An unexpected error occurred. Please try again.";
            ToastService.ShowError(ex.Message);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetRedirectUrl(UserDto user)
    {
        if (!string.IsNullOrEmpty(ReturnUrl))
        {
            if (Uri.TryCreate(ReturnUrl, UriKind.Relative, out _)) return ReturnUrl;
            if (Uri.TryCreate(ReturnUrl, UriKind.Absolute, out Uri? absoluteReturnUrl) && absoluteReturnUrl.Host == new Uri(NavigationManager.BaseUri).Host)
            {
                return absoluteReturnUrl.PathAndQuery;
            }
        }

        if (user.Roles.Contains(ApplicationRoles.Admin)) return "/admin/dashboard";
        if (user.Roles.Contains(ApplicationRoles.Supplier)) return "/supplier/dashboard";
        if (user.Roles.Contains(ApplicationRoles.Buyer)) return "/buyer/dashboard";
        return "/";
    }
}
