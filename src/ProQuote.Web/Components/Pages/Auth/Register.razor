@page "/register"
@layout AuthLayout
@rendermode InteractiveServer
@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Register - ProQuote</PageTitle>

<div style="max-width:560px;margin:var(--pq-space-8) auto;">
    <PqCard>
        <h1 class="pq-section-title">Create Buyer Account</h1>
        <EditForm Model="_registerRequest" OnValidSubmit="HandleRegisterAsync" FormName="registerForm">
            <DataAnnotationsValidator />
            <div class="pq-flex pq-flex-col pq-gap-3" style="margin-top:var(--pq-space-4);">
                <PqInput Label="First Name" Value="@_registerRequest.FirstName" ValueChanged="@(v => _registerRequest.FirstName = v ?? string.Empty)" Disabled="_isLoading" />
                <PqInput Label="Last Name" Value="@_registerRequest.LastName" ValueChanged="@(v => _registerRequest.LastName = v ?? string.Empty)" Disabled="_isLoading" />
                <PqInput Label="Email" Type="email" Value="@_registerRequest.Email" ValueChanged="@(v => _registerRequest.Email = v ?? string.Empty)" Disabled="_isLoading" />
                <PqInput Label="Phone Number" Value="@_registerRequest.PhoneNumber" ValueChanged="@(v => _registerRequest.PhoneNumber = v)" Disabled="_isLoading" />
                <PqInput Label="Password" Type="password" Value="@_registerRequest.Password" ValueChanged="@(v => _registerRequest.Password = v ?? string.Empty)" Disabled="_isLoading" />
                <PqInput Label="Confirm Password" Type="password" Value="@_registerRequest.ConfirmPassword" ValueChanged="@(v => _registerRequest.ConfirmPassword = v ?? string.Empty)" Disabled="_isLoading" />

                @if (_errors.Count > 0)
                {
                    <ul>
                        @foreach (string error in _errors)
                        {
                            <li class="pq-caption" style="color:var(--pq-danger-text)">@error</li>
                        }
                    </ul>
                }

                <PqButton Variant="primary" Type="submit" Loading="_isLoading" FullWidth="true">Create Account</PqButton>
            </div>
        </EditForm>
        <div style="margin-top:var(--pq-space-4);display:flex;gap:var(--pq-space-2);">
            <a href="/login">Sign In</a>
            <a href="/register/supplier">Register as Supplier</a>
        </div>
    </PqCard>
</div>

@code {
    private RegisterRequest _registerRequest = new();
    private bool _isLoading;
    private List<string> _errors = [];

    private async Task HandleRegisterAsync()
    {
        _isLoading = true;
        _errors.Clear();
        try
        {
            AuthResponse response = await AuthService.RegisterBuyerAsync(_registerRequest);
            if (response.Succeeded)
            {
                ToastService.ShowSuccess("Account created successfully! Please sign in.");
                NavigationManager.NavigateTo("/login");
            }
            else
            {
                _errors = response.Errors.Count > 0 ? response.Errors.ToList() : [response.ErrorMessage ?? "Registration failed."];
            }
        }
        catch (Exception ex)
        {
            _errors = [$"An unexpected error occurred: {ex.Message}"];
        }
        finally
        {
            _isLoading = false;
        }
    }
}
