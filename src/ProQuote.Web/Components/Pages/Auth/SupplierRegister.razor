@page "/register/supplier"
@rendermode InteractiveServer
@inject IAuthService AuthService
@inject IUnitOfWork UnitOfWork
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Supplier Registration - ProQuote</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8 mb-8">
    <MudPaper Elevation="3" Class="pa-8">
        <MudStack Spacing="4">
            <div class="text-center">
                <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Primary" Size="Size.Large" Style="font-size: 3rem;" />
                <MudText Typo="Typo.h4" Class="mt-2">Supplier Registration</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Register your company to receive RFQs and submit quotes</MudText>
            </div>

            <MudTabs @bind-ActivePanelIndex="_activeTab" Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
                @* Tab 1: Account Information *@
                <MudTabPanel Text="Account" Icon="@Icons.Material.Filled.Person">
                    <MudGrid Class="mt-2">
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_request.FirstName"
                                          Label="First Name *"
                                          Variant="Variant.Outlined"
                                          Disabled="_isLoading" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_request.LastName"
                                          Label="Last Name *"
                                          Variant="Variant.Outlined"
                                          Disabled="_isLoading" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_request.Email"
                                          Label="Email *"
                                          Variant="Variant.Outlined"
                                          InputType="InputType.Email"
                                          Disabled="_isLoading" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_request.PhoneNumber"
                                          Label="Phone Number"
                                          Variant="Variant.Outlined"
                                          Disabled="_isLoading" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_request.Password"
                                          Label="Password *"
                                          Variant="Variant.Outlined"
                                          InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                          Disabled="_isLoading"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@(_showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                          OnAdornmentClick="@(() => _showPassword = !_showPassword)"
                                          HelperText="Min 8 characters" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_request.ConfirmPassword"
                                          Label="Confirm Password *"
                                          Variant="Variant.Outlined"
                                          InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                          Disabled="_isLoading" />
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                @* Tab 2: Company Information *@
                <MudTabPanel Text="Company" Icon="@Icons.Material.Filled.Business">
                    <MudGrid Class="mt-2">
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_request.CompanyName"
                                          Label="Company Name *"
                                          Variant="Variant.Outlined"
                                          Disabled="_isLoading" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_request.ContactName"
                                          Label="Contact Person Name *"
                                          Variant="Variant.Outlined"
                                          Disabled="_isLoading" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_request.Website"
                                          Label="Website"
                                          Variant="Variant.Outlined"
                                          Placeholder="https://www.example.com"
                                          Disabled="_isLoading" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_request.TaxId"
                                          Label="Tax ID / VAT Number"
                                          Variant="Variant.Outlined"
                                          Disabled="_isLoading" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_request.Address"
                                          Label="Address"
                                          Variant="Variant.Outlined"
                                          Lines="2"
                                          Disabled="_isLoading" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_request.City"
                                          Label="City"
                                          Variant="Variant.Outlined"
                                          Disabled="_isLoading" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_request.Country"
                                          Label="Country"
                                          Variant="Variant.Outlined"
                                          Disabled="_isLoading" />
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                @* Tab 3: Categories *@
                <MudTabPanel Text="Categories" Icon="@Icons.Material.Filled.Category">
                    <MudText Typo="Typo.body1" Class="mt-2 mb-4">
                        Select the categories your company can provide products or services in:
                    </MudText>
                    <MudGrid>
                        @foreach (Domain.Entities.Category category in _categories)
                        {
                            <MudItem xs="12" sm="6" md="4">
                                <MudCheckBox T="bool"
                                             Value="_selectedCategories.Contains(category.Id)"
                                             ValueChanged="@((bool value) => ToggleCategory(category.Id, value))"
                                             Label="@category.Name"
                                             Color="Color.Primary" />
                            </MudItem>
                        }
                    </MudGrid>
                </MudTabPanel>
            </MudTabs>

            @if (_errors.Count > 0)
            {
                <MudAlert Severity="Severity.Error" Dense="true">
                    <ul class="mb-0">
                        @foreach (string error in _errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </MudAlert>
            }

            <MudStack Row="true" Justify="Justify.SpaceBetween">
                <MudButton Variant="Variant.Text" OnClick="PreviousTab" Disabled="_activeTab == 0">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Class="mr-1" /> Back
                </MudButton>
                <MudStack Row="true" Spacing="2">
                    @if (_activeTab < 2)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NextTab">
                            Next <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Class="ml-1" />
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   OnClick="HandleRegisterAsync"
                                   Disabled="_isLoading">
                            @if (_isLoading)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Submitting...</span>
                            }
                            else
                            {
                                <span>Submit Registration</span>
                            }
                        </MudButton>
                    }
                </MudStack>
            </MudStack>

            <MudDivider />

            <MudStack Row="true" Justify="Justify.Center" Spacing="1">
                <MudText Typo="Typo.body2">Already have an account?</MudText>
                <MudLink Href="/login" Typo="Typo.body2">Sign In</MudLink>
            </MudStack>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    #region Fields

    private int _activeTab;
    private SupplierRegisterRequest _request = new();
    private List<Domain.Entities.Category> _categories = [];
    private HashSet<Guid> _selectedCategories = [];
    private bool _isLoading;
    private bool _showPassword;
    private List<string> _errors = [];

    #endregion

    #region Lifecycle

    protected override async Task OnInitializedAsync()
    {
        IReadOnlyList<Domain.Entities.Category> allCategories = await UnitOfWork.Categories.GetTopLevelCategoriesAsync();
        _categories = allCategories.ToList();
    }

    #endregion

    #region Methods

    private void NextTab()
    {
        if (_activeTab < 2)
        {
            _activeTab++;
        }
    }

    private void PreviousTab()
    {
        if (_activeTab > 0)
        {
            _activeTab--;
        }
    }

    private void ToggleCategory(Guid categoryId, bool isSelected)
    {
        if (isSelected)
        {
            _selectedCategories.Add(categoryId);
        }
        else
        {
            _selectedCategories.Remove(categoryId);
        }
    }

    private async Task HandleRegisterAsync()
    {
        _isLoading = true;
        _errors.Clear();

        // Validate
        if (string.IsNullOrWhiteSpace(_request.FirstName) ||
            string.IsNullOrWhiteSpace(_request.LastName) ||
            string.IsNullOrWhiteSpace(_request.Email) ||
            string.IsNullOrWhiteSpace(_request.Password) ||
            string.IsNullOrWhiteSpace(_request.CompanyName) ||
            string.IsNullOrWhiteSpace(_request.ContactName))
        {
            _errors.Add("Please fill in all required fields (marked with *).");
            _isLoading = false;
            return;
        }

        if (_request.Password != _request.ConfirmPassword)
        {
            _errors.Add("Passwords do not match.");
            _isLoading = false;
            return;
        }

        try
        {
            _request.CategoryIds = _selectedCategories.ToList();

            AuthResponse response = await AuthService.RegisterSupplierAsync(_request);

            if (response.Succeeded)
            {
                Snackbar.Add("Registration submitted! Your account is pending admin approval.", Severity.Success);
                NavigationManager.NavigateTo("/login");
            }
            else
            {
                _errors = response.Errors.Count > 0 ? response.Errors : [response.ErrorMessage ?? "Registration failed."];
            }
        }
        catch (Exception ex)
        {
            _errors = [$"An unexpected error occurred: {ex.Message}"];
        }
        finally
        {
            _isLoading = false;
        }
    }

    #endregion
}
