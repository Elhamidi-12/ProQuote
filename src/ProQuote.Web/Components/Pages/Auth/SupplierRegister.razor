@page "/register/supplier"
@layout AuthLayout
@rendermode InteractiveServer
@inject IAuthService AuthService
@inject IUnitOfWork UnitOfWork
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Supplier Registration - ProQuote</PageTitle>

<div style="max-width:700px;margin:var(--pq-space-8) auto;">
    <PqCard>
        <h1 class="pq-section-title">Supplier Registration</h1>
        <div class="pq-flex pq-flex-col pq-gap-3" style="margin-top:var(--pq-space-4);">
            <PqInput Label="First Name" Value="@_request.FirstName" ValueChanged="@(v => _request.FirstName = v ?? string.Empty)" Disabled="_isLoading" />
            <PqInput Label="Last Name" Value="@_request.LastName" ValueChanged="@(v => _request.LastName = v ?? string.Empty)" Disabled="_isLoading" />
            <PqInput Label="Email" Type="email" Value="@_request.Email" ValueChanged="@(v => _request.Email = v ?? string.Empty)" Disabled="_isLoading" />
            <PqInput Label="Phone Number" Value="@_request.PhoneNumber" ValueChanged="@(v => _request.PhoneNumber = v)" Disabled="_isLoading" />
            <PqInput Label="Password" Type="password" Value="@_request.Password" ValueChanged="@(v => _request.Password = v ?? string.Empty)" Disabled="_isLoading" />
            <PqInput Label="Confirm Password" Type="password" Value="@_request.ConfirmPassword" ValueChanged="@(v => _request.ConfirmPassword = v ?? string.Empty)" Disabled="_isLoading" />
            <PqInput Label="Company Name" Value="@_request.CompanyName" ValueChanged="@(v => _request.CompanyName = v ?? string.Empty)" Disabled="_isLoading" />
            <PqInput Label="Contact Name" Value="@_request.ContactName" ValueChanged="@(v => _request.ContactName = v ?? string.Empty)" Disabled="_isLoading" />
            <PqInput Label="Website" Value="@_request.Website" ValueChanged="@(v => _request.Website = v)" Disabled="_isLoading" />
            <PqInput Label="Tax ID" Value="@_request.TaxId" ValueChanged="@(v => _request.TaxId = v)" Disabled="_isLoading" />
            <PqInput Label="Address" Value="@_request.Address" ValueChanged="@(v => _request.Address = v)" Disabled="_isLoading" />
            <PqInput Label="City" Value="@_request.City" ValueChanged="@(v => _request.City = v)" Disabled="_isLoading" />
            <PqInput Label="Country" Value="@_request.Country" ValueChanged="@(v => _request.Country = v)" Disabled="_isLoading" />

            <div>
                <div class="pq-label" style="margin-bottom:var(--pq-space-2);">Categories</div>
                <div class="pq-flex" style="flex-wrap:wrap;gap:var(--pq-space-3);">
                    @foreach (Domain.Entities.Category category in _categories)
                    {
                        <label class="pq-body-sm" style="display:inline-flex;gap:var(--pq-space-1);align-items:center;">
                            <input type="checkbox" checked="@_selectedCategories.Contains(category.Id)" @onchange="(e => ToggleCategory(category.Id, (bool)e.Value!))" />
                            @category.Name
                        </label>
                    }
                </div>
            </div>

            @if (_errors.Count > 0)
            {
                <ul>
                    @foreach (string error in _errors)
                    {
                        <li class="pq-caption" style="color:var(--pq-danger-text)">@error</li>
                    }
                </ul>
            }

            <PqButton Variant="primary" Loading="_isLoading" OnClick="HandleRegisterAsync" FullWidth="true">Submit Registration</PqButton>
        </div>
        <div style="margin-top:var(--pq-space-4);"><a href="/login">Sign In</a></div>
    </PqCard>
</div>

@code {
    private SupplierRegisterRequest _request = new();
    private List<Domain.Entities.Category> _categories = [];
    private HashSet<Guid> _selectedCategories = [];
    private bool _isLoading;
    private List<string> _errors = [];

    protected override async Task OnInitializedAsync()
    {
        IReadOnlyList<Domain.Entities.Category> allCategories = await UnitOfWork.Categories.GetTopLevelCategoriesAsync();
        _categories = allCategories.ToList();
    }

    private void ToggleCategory(Guid categoryId, bool isSelected)
    {
        if (isSelected) _selectedCategories.Add(categoryId); else _selectedCategories.Remove(categoryId);
    }

    private async Task HandleRegisterAsync()
    {
        _isLoading = true;
        _errors.Clear();

        if (string.IsNullOrWhiteSpace(_request.FirstName) ||
            string.IsNullOrWhiteSpace(_request.LastName) ||
            string.IsNullOrWhiteSpace(_request.Email) ||
            string.IsNullOrWhiteSpace(_request.Password) ||
            string.IsNullOrWhiteSpace(_request.CompanyName) ||
            string.IsNullOrWhiteSpace(_request.ContactName))
        {
            _errors.Add("Please fill in all required fields.");
            _isLoading = false;
            return;
        }

        if (_request.Password != _request.ConfirmPassword)
        {
            _errors.Add("Passwords do not match.");
            _isLoading = false;
            return;
        }

        try
        {
            _request.CategoryIds = [.. _selectedCategories];
            AuthResponse response = await AuthService.RegisterSupplierAsync(_request);

            if (response.Succeeded)
            {
                ToastService.ShowSuccess("Registration submitted! Your account is pending admin approval.");
                NavigationManager.NavigateTo("/login");
            }
            else
            {
                _errors = response.Errors.Count > 0 ? response.Errors.ToList() : [response.ErrorMessage ?? "Registration failed."];
            }
        }
        catch (Exception ex)
        {
            _errors = [$"An unexpected error occurred: {ex.Message}"];
        }
        finally
        {
            _isLoading = false;
        }
    }
}
