@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using ProQuote.Application.DTOs.Quotes
@inject IQuoteSubmissionService QuoteSubmissionService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ToastService ToastService

<h1 class="pq-section-title">@Title</h1>
<PqCard>
    @if (_isLoading)
    {
        <p class="pq-body-sm">Loading invitations...</p>
    }
    else if (_invitations.Count == 0)
    {
        <p class="pq-body-sm">No invitations found.</p>
    }
    else
    {
        <PqTable Headers="_headers">
            @foreach (SupplierInvitationItemDto invitation in _invitations)
            {
                <tr>
                    <td>@invitation.ReferenceNumber</td>
                    <td>@invitation.Title</td>
                    <td>@invitation.CategoryName</td>
                    <td>@invitation.SubmissionDeadline.ToString("MMM dd, yyyy")</td>
                    <td><PqBadge Variant="@GetInvitationBadgeVariant(invitation.Status)">@invitation.Status</PqBadge></td>
                    <td>
                        @if (invitation.HasQuote)
                        {
                            <PqBadge Variant="published">Quoted</PqBadge>
                        }
                        else
                        {
                            <PqBadge Variant="pending">Pending</PqBadge>
                        }
                    </td>
                    <td>
                        <a href="@($"/supplier/rfqs/{invitation.RfqId}/quote")">
                            <PqButton Variant="primary" Size="sm">@((invitation.HasQuote ? "Edit Quote" : "Create Quote"))</PqButton>
                        </a>
                    </td>
                </tr>
            }
        </PqTable>
    }
</PqCard>

@code {
    [Parameter] public string Title { get; set; } = "Invitations";
    [Parameter] public Domain.Enums.InvitationStatus? StatusFilter { get; set; }

    private bool _isLoading = true;
    private List<SupplierInvitationItemDto> _invitations = [];

    private readonly List<PqTable.TableColumn> _headers =
    [
        new() { Label = "Reference", Field = "reference" },
        new() { Label = "RFQ", Field = "rfq" },
        new() { Label = "Category", Field = "category" },
        new() { Label = "Deadline", Field = "deadline" },
        new() { Label = "Invitation", Field = "invitation" },
        new() { Label = "Quote", Field = "quote" },
        new() { Label = "Actions", Field = "actions", Width = "160px" }
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            Guid? userId = await GetCurrentUserIdAsync();
            if (!userId.HasValue)
            {
                ToastService.ShowError("Unable to resolve current user.");
                return;
            }

            IReadOnlyList<SupplierInvitationItemDto> invitations =
                await QuoteSubmissionService.GetSupplierInvitationsAsync(userId.Value, StatusFilter);
            _invitations = invitations.ToList();
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message, "Failed to load invitations");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task<Guid?> GetCurrentUserIdAsync()
    {
        AuthenticationState authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        string? userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        return Guid.TryParse(userId, out Guid parsedUserId) ? parsedUserId : null;
    }

    private static string GetInvitationBadgeVariant(Domain.Enums.InvitationStatus status)
    {
        return status switch
        {
            Domain.Enums.InvitationStatus.Sent => "pending",
            Domain.Enums.InvitationStatus.Viewed => "published",
            Domain.Enums.InvitationStatus.Quoted => "awarded",
            Domain.Enums.InvitationStatus.Declined => "cancelled",
            _ => "default"
        };
    }
}
