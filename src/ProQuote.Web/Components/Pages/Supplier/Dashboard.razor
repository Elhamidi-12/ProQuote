@page "/supplier/dashboard"
@rendermode InteractiveServer
@layout SupplierLayout
@attribute [Authorize(Roles = ApplicationRoles.Supplier)]

<PageTitle>Supplier Dashboard - ProQuote</PageTitle>

<div class="pq-flex pq-flex-col pq-gap-4">
    <h1 class="pq-section-title">Supplier Dashboard</h1>

    <div class="dashboard-grid">
        <PqStatCard Title="New Invitations" Value="@_stats.NewInvitations.ToString()" />
        <PqStatCard Title="Pending Quotes" Value="@_stats.PendingQuotes.ToString()" />
        <PqStatCard Title="Submitted Quotes" Value="@_stats.SubmittedQuotes.ToString()" />
        <PqStatCard Title="Won Contracts" Value="@_stats.WonContracts.ToString()" />
    </div>

    <PqCard>
        <h2 class="pq-card-title">New RFQ Invitations</h2>
        <ul style="margin-top:var(--pq-space-3);display:flex;flex-direction:column;gap:var(--pq-space-2);">
            @foreach (RfqInvitationItem invitation in _newInvitations)
            {
                <li class="pq-body-sm">@invitation.ReferenceNumber - @invitation.Title (Due: @invitation.Deadline.ToString("MMM dd, yyyy"))</li>
            }
        </ul>
    </PqCard>
</div>

@code {
    private DashboardStats _stats = new();
    private List<RfqInvitationItem> _newInvitations = [];

    protected override void OnInitialized()
    {
        _stats = new DashboardStats { NewInvitations = 3, PendingQuotes = 2, SubmittedQuotes = 8, WonContracts = 5 };
        _newInvitations =
        [
            new RfqInvitationItem { ReferenceNumber = "RFQ-2025-00045", Title = "Office IT Equipment Procurement", Deadline = DateTime.UtcNow.AddDays(7) },
            new RfqInvitationItem { ReferenceNumber = "RFQ-2025-00044", Title = "Software Development Services", Deadline = DateTime.UtcNow.AddDays(10) },
            new RfqInvitationItem { ReferenceNumber = "RFQ-2025-00043", Title = "Cloud Infrastructure Setup", Deadline = DateTime.UtcNow.AddDays(14) }
        ];
    }

    private class DashboardStats
    {
        public int NewInvitations { get; set; }
        public int PendingQuotes { get; set; }
        public int SubmittedQuotes { get; set; }
        public int WonContracts { get; set; }
    }

    private class RfqInvitationItem
    {
        public string ReferenceNumber { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public DateTime Deadline { get; set; }
    }
}
