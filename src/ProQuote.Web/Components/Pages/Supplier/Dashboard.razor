@page "/supplier/dashboard"
@rendermode InteractiveServer
@layout SupplierLayout
@attribute [Authorize(Roles = ApplicationRoles.Supplier)]
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using ProQuote.Application.DTOs.Quotes
@inject IQuoteSubmissionService QuoteSubmissionService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ToastService ToastService

<PageTitle>Supplier Dashboard - ProQuote</PageTitle>

<div class="pq-flex pq-flex-col pq-gap-4">
    <h1 class="pq-section-title">Supplier Dashboard</h1>

    <div class="dashboard-grid">
        <PqStatCard Title="New Invitations" Value="@_stats.NewInvitations.ToString()" />
        <PqStatCard Title="Pending Quotes" Value="@_stats.PendingQuotes.ToString()" />
        <PqStatCard Title="Submitted Quotes" Value="@_stats.SubmittedQuotes.ToString()" />
        <PqStatCard Title="Won Contracts" Value="@_stats.WonContracts.ToString()" />
    </div>

    <PqCard>
        <h2 class="pq-card-title">New RFQ Invitations</h2>
        @if (_isLoading)
        {
            <p class="pq-body-sm" style="margin-top:var(--pq-space-2);">Loading invitations...</p>
        }
        else if (_newInvitations.Count == 0)
        {
            <p class="pq-body-sm" style="margin-top:var(--pq-space-2);">No new invitations.</p>
        }
        else
        {
            <ul style="margin-top:var(--pq-space-3);display:flex;flex-direction:column;gap:var(--pq-space-2);">
            @foreach (SupplierInvitationItemDto invitation in _newInvitations)
            {
                <li class="pq-body-sm">@invitation.ReferenceNumber - @invitation.Title (Due: @invitation.SubmissionDeadline.ToLocalTime().ToString("MMM dd, yyyy"))</li>
            }
            </ul>
        }
    </PqCard>
</div>

@code {
    private DashboardStats _stats = new();
    private bool _isLoading = true;
    private List<SupplierInvitationItemDto> _newInvitations = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            Guid? userId = await GetCurrentUserIdAsync();
            if (!userId.HasValue)
            {
                ToastService.ShowError("Unable to resolve current user.");
                return;
            }

            IReadOnlyList<SupplierInvitationItemDto> invitations =
                await QuoteSubmissionService.GetSupplierInvitationsAsync(userId.Value);
            IReadOnlyList<SupplierQuoteListItemDto> quotes =
                await QuoteSubmissionService.GetSupplierQuotesAsync(userId.Value);

            _newInvitations = invitations
                .Where(i =>
                    (i.Status == Domain.Enums.InvitationStatus.Sent || i.Status == Domain.Enums.InvitationStatus.Viewed) &&
                    !i.HasQuote &&
                    i.SubmissionDeadline > DateTime.UtcNow)
                .OrderBy(i => i.SubmissionDeadline)
                .Take(5)
                .ToList();

            _stats = new DashboardStats
            {
                NewInvitations = _newInvitations.Count,
                PendingQuotes = invitations.Count(i =>
                    (i.Status == Domain.Enums.InvitationStatus.Sent || i.Status == Domain.Enums.InvitationStatus.Viewed) &&
                    !i.HasQuote &&
                    i.SubmissionDeadline > DateTime.UtcNow),
                SubmittedQuotes = quotes.Count(q =>
                    q.Status == Domain.Enums.QuoteStatus.Submitted ||
                    q.Status == Domain.Enums.QuoteStatus.Awarded ||
                    q.Status == Domain.Enums.QuoteStatus.Rejected),
                WonContracts = quotes.Count(q => q.IsAwarded || q.Status == Domain.Enums.QuoteStatus.Awarded)
            };
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message, "Failed to load dashboard");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private class DashboardStats
    {
        public int NewInvitations { get; set; }
        public int PendingQuotes { get; set; }
        public int SubmittedQuotes { get; set; }
        public int WonContracts { get; set; }
    }

    private async Task<Guid?> GetCurrentUserIdAsync()
    {
        AuthenticationState authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        string? userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        return Guid.TryParse(userId, out Guid parsedUserId) ? parsedUserId : null;
    }
}
