@page "/supplier/rfqs/{RfqId:guid}/quote"
@rendermode InteractiveServer
@layout SupplierLayout
@attribute [Authorize(Roles = ApplicationRoles.Supplier)]
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@using ProQuote.Application.DTOs.Quotes
@inject IQuoteSubmissionService QuoteSubmissionService
@inject ProQuote.Infrastructure.Data.AppDbContext DbContext
@inject IWebHostEnvironment HostEnvironment
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject ToastService ToastService

<PageTitle>Submit Quote - ProQuote</PageTitle>

<h1 class="pq-section-title">Submit Quote</h1>

@if (_isLoading)
{
    <PqCard>
        <p class="pq-body-sm">Loading quote editor...</p>
    </PqCard>
}
else if (_editor is null)
{
    <PqCard>
        <p class="pq-body-sm">Quote editor is unavailable.</p>
    </PqCard>
}
else
{
    <div class="pq-flex pq-flex-col pq-gap-4">
        <PqCard>
            <h2 class="pq-card-title">@_editor.ReferenceNumber - @_editor.RfqTitle</h2>
            <div class="pq-flex pq-gap-3" style="flex-wrap:wrap;margin-top:var(--pq-space-2);">
                <PqBadge Variant="published">Currency: @_editor.Currency</PqBadge>
                <PqBadge Variant="pending">Deadline: @_editor.SubmissionDeadline.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</PqBadge>
            </div>
        </PqCard>

        <PqCard>
            <h2 class="pq-card-title">Commercial Terms</h2>
            <div class="pq-flex pq-flex-col pq-gap-3" style="margin-top:var(--pq-space-3);">
                <PqInput Label="Lead Time (Days)"
                         Type="number"
                         Value="@_leadTimeDays"
                         ValueChanged="@(v => _leadTimeDays = v ?? "14")"
                         Disabled="_isSaving" />
                <PqInput Label="Valid Until (UTC)"
                         Type="datetime-local"
                         Value="@_validUntil"
                         ValueChanged="@(v => _validUntil = v ?? string.Empty)"
                         Disabled="_isSaving" />
                <PqInput Label="Payment Terms"
                         Value="@_paymentTerms"
                         ValueChanged="@(v => _paymentTerms = v)"
                         Disabled="_isSaving" />
                <PqTextarea Label="Notes"
                            Value="@_notes"
                            ValueChanged="@(v => _notes = v)"
                            Disabled="_isSaving" />
            </div>
        </PqCard>

        <PqCard>
            <h2 class="pq-card-title">Line Item Pricing</h2>
            <div style="margin-top:var(--pq-space-3);">
                <PqTable Headers="_lineItemHeaders">
                    @foreach (QuoteEditorLineItemDto item in _editor.LineItems)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Quantity.ToString("N2") @item.UnitOfMeasure</td>
                            <td style="width:180px;">
                                <PqInput Type="number"
                                         Value="@GetUnitPrice(item.LineItemId)"
                                         ValueChanged="@(v => SetUnitPrice(item.LineItemId, v))"
                                         Disabled="_isSaving" />
                            </td>
                            <td>@GetLineTotal(item).ToString("N2")</td>
                        </tr>
                    }
                </PqTable>
            </div>
            <div style="display:flex;justify-content:flex-end;margin-top:var(--pq-space-3);">
                <PqBadge Variant="awarded">Total: @GetQuoteTotal().ToString("N2") @_editor.Currency</PqBadge>
            </div>
        </PqCard>

        <PqCard>
            <h2 class="pq-card-title">Supporting Documents</h2>
            <p class="pq-body-sm" style="margin-top:var(--pq-space-2);">
                Attach optional quote files (proposal, certifications, datasheets). Max file size: 10 MB.
            </p>
            <div style="margin-top:var(--pq-space-3);">
                <InputFile OnChange="HandleFilesSelectedAsync" multiple />
            </div>

            @if (_pendingUploads.Count > 0)
            {
                <div style="margin-top:var(--pq-space-3);">
                    <p class="pq-body-sm"><strong>Pending uploads</strong></p>
                    <ul class="pq-body-sm" style="margin-top:var(--pq-space-2);padding-left:1rem;">
                        @foreach (PendingUpload pending in _pendingUploads)
                        {
                            <li>@pending.File.Name (@FormatFileSize(pending.File.Size))</li>
                        }
                    </ul>
                </div>
            }

            @if (_existingDocuments.Count > 0)
            {
                <div style="margin-top:var(--pq-space-3);">
                    <p class="pq-body-sm"><strong>Attached documents</strong></p>
                    <ul class="pq-body-sm" style="margin-top:var(--pq-space-2);padding-left:1rem;">
                        @foreach (Domain.Entities.QuoteDocument doc in _existingDocuments)
                        {
                            <li style="display:flex;align-items:center;gap:var(--pq-space-2);flex-wrap:wrap;">
                                <a href="@doc.FilePath" target="_blank">@doc.FileName</a>
                                <span>(@FormatFileSize(doc.FileSize))</span>
                                <PqButton Variant="danger"
                                          Size="sm"
                                          OnClick="@(() => RemoveDocumentAsync(doc.Id))"
                                          Disabled="_isSaving">
                                    Remove
                                </PqButton>
                            </li>
                        }
                    </ul>
                </div>
            }
        </PqCard>

        <div style="display:flex;gap:var(--pq-space-2);justify-content:flex-end;flex-wrap:wrap;">
            <a href="/supplier/quotes"><PqButton Variant="ghost">Cancel</PqButton></a>
            <PqButton Variant="primary" OnClick="SaveQuoteAsync" Loading="_isSaving">Submit Quote</PqButton>
        </div>
    </div>
}

@code {
    [Parameter] public Guid RfqId { get; set; }

    private bool _isLoading = true;
    private bool _isSaving;
    private Guid? _currentUserId;

    private QuoteEditorDto? _editor;
    private string _leadTimeDays = "14";
    private string _validUntil = string.Empty;
    private string? _paymentTerms;
    private string? _notes;
    private readonly Dictionary<Guid, string> _unitPrices = [];
    private List<PendingUpload> _pendingUploads = [];
    private List<Domain.Entities.QuoteDocument> _existingDocuments = [];
    private const long MaxUploadBytes = 10 * 1024 * 1024;

    private readonly List<PqTable.TableColumn> _lineItemHeaders =
    [
        new() { Label = "Line Item", Field = "lineItem" },
        new() { Label = "Requested Qty", Field = "quantity" },
        new() { Label = "Unit Price", Field = "unitPrice" },
        new() { Label = "Line Total", Field = "lineTotal" }
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            _currentUserId = await GetCurrentUserIdAsync();
            if (!_currentUserId.HasValue)
            {
                ToastService.ShowError("Unable to resolve current user.");
                return;
            }

            _editor = await QuoteSubmissionService.GetQuoteEditorAsync(_currentUserId.Value, RfqId);
            if (_editor == null)
            {
                ToastService.ShowError("RFQ quote editor not available.");
                return;
            }

            _leadTimeDays = _editor.LeadTimeDays.ToString();
            _validUntil = _editor.ValidUntil.ToString("yyyy-MM-ddTHH:mm");
            _paymentTerms = _editor.PaymentTerms;
            _notes = _editor.Notes;
            _unitPrices.Clear();
            foreach (QuoteEditorLineItemDto lineItem in _editor.LineItems)
            {
                _unitPrices[lineItem.LineItemId] = lineItem.UnitPrice.ToString(System.Globalization.CultureInfo.InvariantCulture);
            }

            await LoadExistingDocumentsAsync(_editor.QuoteId);
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message, "Failed to load quote editor");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetUnitPrice(Guid lineItemId)
    {
        return _unitPrices.TryGetValue(lineItemId, out string? value) ? value : "0";
    }

    private void SetUnitPrice(Guid lineItemId, string? value)
    {
        _unitPrices[lineItemId] = value ?? "0";
    }

    private decimal GetLineTotal(QuoteEditorLineItemDto lineItem)
    {
        decimal unitPrice = ParseDecimal(GetUnitPrice(lineItem.LineItemId));
        return decimal.Round(unitPrice * lineItem.Quantity, 2);
    }

    private decimal GetQuoteTotal()
    {
        if (_editor == null)
        {
            return 0m;
        }

        return _editor.LineItems.Sum(GetLineTotal);
    }

    private async Task LoadExistingDocumentsAsync(Guid? quoteId)
    {
        if (!quoteId.HasValue)
        {
            _existingDocuments = [];
            return;
        }

        _existingDocuments = await DbContext.QuoteDocuments
            .Where(d => d.QuoteId == quoteId.Value)
            .OrderBy(d => d.DisplayOrder)
            .ToListAsync();
    }

    private async Task SaveQuoteAsync()
    {
        if (!_currentUserId.HasValue || _editor == null)
        {
            ToastService.ShowError("Unable to resolve quote context.");
            return;
        }

        if (!int.TryParse(_leadTimeDays, out int leadTimeDays) || leadTimeDays < 0)
        {
            ToastService.ShowError("Lead time must be a non-negative number.");
            return;
        }

        if (!DateTime.TryParse(_validUntil, out DateTime validUntil))
        {
            ToastService.ShowError("Valid until date is invalid.");
            return;
        }

        List<SaveQuoteLineItemRequest> lineItems = _editor.LineItems
            .Select(li => new SaveQuoteLineItemRequest
            {
                LineItemId = li.LineItemId,
                UnitPrice = ParseDecimal(GetUnitPrice(li.LineItemId)),
                Notes = li.Notes
            })
            .ToList();

        if (lineItems.All(li => li.UnitPrice <= 0m))
        {
            ToastService.ShowError("At least one line item must have a positive unit price.");
            return;
        }

        SaveQuoteRequest request = new()
        {
            RfqId = _editor.RfqId,
            LeadTimeDays = leadTimeDays,
            ValidUntil = validUntil.ToUniversalTime(),
            PaymentTerms = _paymentTerms,
            Notes = _notes,
            LineItems = lineItems
        };

        _isSaving = true;
        try
        {
            QuoteSaveResponse response = await QuoteSubmissionService.SaveQuoteAsync(_currentUserId.Value, request);
            if (!response.Succeeded)
            {
                ToastService.ShowError(response.ErrorMessage ?? "Failed to submit quote.");
                return;
            }

            if (!response.QuoteId.HasValue)
            {
                ToastService.ShowError("Quote saved but missing quote identifier.");
                return;
            }

            await SavePendingDocumentsAsync(response.QuoteId.Value);

            ToastService.ShowSuccess("Quote submitted successfully.");
            NavigationManager.NavigateTo("/supplier/quotes");
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task HandleFilesSelectedAsync(InputFileChangeEventArgs args)
    {
        IReadOnlyList<IBrowserFile> files = args.GetMultipleFiles();
        foreach (IBrowserFile file in files)
        {
            if (file.Size <= 0)
            {
                continue;
            }

            if (file.Size > MaxUploadBytes)
            {
                ToastService.ShowError($"{file.Name} exceeds 10 MB and was skipped.");
                continue;
            }

            _pendingUploads.Add(new PendingUpload(file));
        }
    }

    private async Task SavePendingDocumentsAsync(Guid quoteId)
    {
        if (_pendingUploads.Count == 0)
        {
            return;
        }

        string webRoot = string.IsNullOrWhiteSpace(HostEnvironment.WebRootPath)
            ? Path.Combine(HostEnvironment.ContentRootPath, "wwwroot")
            : HostEnvironment.WebRootPath;
        string targetDir = Path.Combine(webRoot, "uploads", "quotes", quoteId.ToString("N"));
        Directory.CreateDirectory(targetDir);

        int displayOrder = _existingDocuments.Count > 0 ? _existingDocuments.Max(d => d.DisplayOrder) + 1 : 1;
        List<Domain.Entities.QuoteDocument> newDocuments = [];

        foreach (PendingUpload upload in _pendingUploads)
        {
            IBrowserFile file = upload.File;
            string extension = Path.GetExtension(file.Name);
            string storedFileName = $"{Guid.NewGuid():N}{extension}";
            string physicalPath = Path.Combine(targetDir, storedFileName);

            await using Stream sourceStream = file.OpenReadStream(MaxUploadBytes);
            await using FileStream destinationStream = File.Create(physicalPath);
            await sourceStream.CopyToAsync(destinationStream);

            string relativeFilePath = $"/uploads/quotes/{quoteId:N}/{storedFileName}";
            Domain.Entities.QuoteDocument document = new()
            {
                Id = Guid.NewGuid(),
                QuoteId = quoteId,
                FileName = Path.GetFileName(file.Name),
                StoredFileName = storedFileName,
                ContentType = string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType,
                FileSize = file.Size,
                FilePath = relativeFilePath,
                DisplayOrder = displayOrder++,
                UploadedAt = DateTime.UtcNow,
                CreatedAt = DateTime.UtcNow
            };

            newDocuments.Add(document);
        }

        if (newDocuments.Count > 0)
        {
            await DbContext.QuoteDocuments.AddRangeAsync(newDocuments);
            await DbContext.SaveChangesAsync();
            _existingDocuments.AddRange(newDocuments);
        }

        _pendingUploads.Clear();
    }

    private async Task RemoveDocumentAsync(Guid documentId)
    {
        Domain.Entities.QuoteDocument? existing = await DbContext.QuoteDocuments.FirstOrDefaultAsync(d => d.Id == documentId);
        if (existing == null)
        {
            return;
        }

        DbContext.QuoteDocuments.Remove(existing);
        await DbContext.SaveChangesAsync();

        string webRoot = string.IsNullOrWhiteSpace(HostEnvironment.WebRootPath)
            ? Path.Combine(HostEnvironment.ContentRootPath, "wwwroot")
            : HostEnvironment.WebRootPath;
        string relativePath = existing.FilePath.TrimStart('/').Replace('/', Path.DirectorySeparatorChar);
        string physicalPath = Path.Combine(webRoot, relativePath);
        if (File.Exists(physicalPath))
        {
            File.Delete(physicalPath);
        }

        _existingDocuments = _existingDocuments
            .Where(d => d.Id != documentId)
            .OrderBy(d => d.DisplayOrder)
            .ToList();

        ToastService.ShowSuccess("Document removed.");
    }

    private async Task<Guid?> GetCurrentUserIdAsync()
    {
        AuthenticationState authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        string? userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        return Guid.TryParse(userId, out Guid parsedUserId) ? parsedUserId : null;
    }

    private static decimal ParseDecimal(string? value)
    {
        if (decimal.TryParse(value, System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out decimal parsed))
        {
            return parsed;
        }

        if (decimal.TryParse(value, out parsed))
        {
            return parsed;
        }

        return 0m;
    }

    private static string FormatFileSize(long bytes)
    {
        string[] sizes = ["B", "KB", "MB", "GB"];
        double size = bytes;
        int order = 0;
        while (size >= 1024 && order < sizes.Length - 1)
        {
            order++;
            size /= 1024;
        }

        return $"{size:0.##} {sizes[order]}";
    }

    private sealed record PendingUpload(IBrowserFile File);
}
