@page "/"
@rendermode InteractiveServer

<PageTitle>ProQuote</PageTitle>

<AuthorizeView>
    <Authorized>
        @* Redirect authenticated users to their role-specific dashboard *@
        <RedirectToDashboard />
    </Authorized>
    <NotAuthorized>
        <div class="home">
            <div class="home__hero">
                <div class="home__logo">PQ</div>
                <h1 class="home__title">ProQuote</h1>
                <p class="home__subtitle">Streamline your procurement process with our powerful RFQ system</p>

                <div class="home__actions">
                    <a href="/login"><PqButton Variant="primary">Sign In</PqButton></a>
                    <a href="/register"><PqButton Variant="secondary">Register as Buyer</PqButton></a>
                    <a href="/register/supplier"><PqButton Variant="ghost">Register as Supplier</PqButton></a>
                    <a href="/showcase"><PqButton Variant="link">UI Showcase</PqButton></a>
                </div>
            </div>

            <div class="home__features">
                <PqCard>
                    <div class="home__feature-title">Fast & Efficient</div>
                    <div class="home__feature-text">Create and manage RFQs in minutes. Streamline your procurement workflow.</div>
                </PqCard>
                <PqCard>
                    <div class="home__feature-title">Easy Comparison</div>
                    <div class="home__feature-text">Compare quotes side-by-side and make informed decisions with detailed analytics.</div>
                </PqCard>
                <PqCard>
                    <div class="home__feature-title">Secure & Compliant</div>
                    <div class="home__feature-text">Full audit trail and secure document management for complete compliance.</div>
                </PqCard>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>
