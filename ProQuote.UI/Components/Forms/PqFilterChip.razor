<button type="button" class="pq-filter-chip @(Active ? "pq-filter-chip--active" : string.Empty)" @onclick="Toggle" aria-pressed="@Active">
    <span>@Label</span>
    @if (Count.HasValue) { <span class="pq-filter-chip__count">@Count</span> }
</button>
@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public bool Active { get; set; }
    [Parameter] public EventCallback<bool> ActiveChanged { get; set; }
    [Parameter] public EventCallback<bool> OnToggle { get; set; }
    [Parameter] public int? Count { get; set; }

    private async Task Toggle()
    {
        Active = !Active;
        await ActiveChanged.InvokeAsync(Active);
        await OnToggle.InvokeAsync(Active);
    }
}
