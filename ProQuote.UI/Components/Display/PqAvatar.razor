<div class="pq-avatar pq-avatar--@Size" style="--pq-avatar-bg:@BackgroundColor;" title="@Name">
    @if (!string.IsNullOrWhiteSpace(Src))
    {
        <img src="@Src" alt="@Name" class="pq-avatar__img" />
    }
    else
    {
        <span>@Initials</span>
    }
    @if (Online)
    {
        <span class="pq-avatar__online" aria-label="online"></span>
    }
</div>

@code {
    [Parameter] public string? Name { get; set; }
    [Parameter] public string? Src { get; set; }
    [Parameter] public string Size { get; set; } = "md";
    [Parameter] public bool Online { get; set; }
    [Parameter] public string? Color { get; set; }

    private string Initials
    {
        get
        {
            if (string.IsNullOrWhiteSpace(Name)) return "?";
            string[] parts = Name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length == 1) return parts[0][0].ToString().ToUpperInvariant();
            return string.Concat(parts[0][0], parts[^1][0]).ToUpperInvariant();
        }
    }

    private string BackgroundColor => !string.IsNullOrWhiteSpace(Color) ? Color : PickColor();

    private string PickColor()
    {
        string[] palette =
        [
            "var(--pq-primary-600)",
            "var(--pq-info-600)",
            "var(--pq-success-600)",
            "var(--pq-warning-600)",
            "var(--pq-danger-600)"
        ];

        int hash = (Name ?? string.Empty).Aggregate(0, (acc, c) => acc + c);
        return palette[Math.Abs(hash) % palette.Length];
    }
}
