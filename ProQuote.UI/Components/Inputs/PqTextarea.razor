<div class="pq-textarea-field">
    <label class="pq-textarea-field__label">@Label</label>
    <textarea class="pq-textarea-field__input" placeholder="@Placeholder" disabled="@Disabled" value="@Value" @oninput="HandleInput"></textarea>
    @if (!string.IsNullOrWhiteSpace(Error)) { <div class="pq-textarea-field__error">@Error</div> }
    else if (!string.IsNullOrWhiteSpace(Hint)) { <div class="pq-textarea-field__hint">@Hint</div> }
</div>
@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public string? Hint { get; set; }
    [Parameter] public bool Disabled { get; set; }
    private Task HandleInput(ChangeEventArgs e) => ValueChanged.InvokeAsync(e.Value?.ToString());
}
