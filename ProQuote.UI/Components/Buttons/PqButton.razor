<button
    class="pq-button pq-button--@Variant pq-button--@Size @(FullWidth ? "pq-button--full" : string.Empty)"
    type="@Type"
    disabled="@(Disabled || Loading)"
    @onclick="HandleClick"
    aria-busy="@Loading"
>
    @if (Loading)
    {
        <svg class="pq-button__spinner" viewBox="0 0 24 24" aria-hidden="true">
            <circle class="pq-button__spinner-track" cx="12" cy="12" r="10"></circle>
            <path class="pq-button__spinner-head" d="M22 12a10 10 0 0 1-10 10"></path>
        </svg>
    }
    @ChildContent
</button>

@code {
    [Parameter] public string Variant { get; set; } = "primary";
    [Parameter] public string Size { get; set; } = "md";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public bool FullWidth { get; set; }
    [Parameter] public string Type { get; set; } = "button";
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private Task HandleClick()
    {
        if (Disabled || Loading)
        {
            return Task.CompletedTask;
        }

        return OnClick.InvokeAsync();
    }
}
